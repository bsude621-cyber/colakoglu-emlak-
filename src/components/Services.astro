---
import { services } from "../data/config";

// Premium çizgi ikonlar — slug bazlı, tutarlı 1.6 stroke (unicode/emoji DEĞİL).
const icons: Record<string, string> = {
  "satis-kiralama":
    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.6 12 3l9 7.6"/><path d="M5.5 9.4V20h13V9.4"/><path d="M10 20v-5.6h4V20"/></svg>',
  "yatirim-danismanligi":
    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16"/><path d="M6.5 16.4 11 11l3.2 2.6L21 6"/><path d="M16.3 6H21v4.7"/></svg>',
  "degerleme-raporlama":
    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l5 5v13H6z"/><path d="M14 3v5h5"/><path d="M9.5 17v-3.4M12.5 17v-6M15.5 17v-2.2"/></svg>',
  "hukuki-eslik":
    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 5 5.6v5.6c0 4.8 3 8 7 9.2 4-1.2 7-4.4 7-9.2V5.6z"/><path d="M9 11.4l2.2 2.2 4-4.4"/></svg>',
};
---

<section id="hizmetler" class="section section-services">
  <div class="container">
    <header class="section-head section-head-center">
      <p class="eyebrow">Ne Sunuyoruz</p>
      <h2>Hizmetlerimiz</h2>
      <p class="section-desc">
        Gayrimenkulünüzün değerini doğru analiz eder; hukuki ve teknik
        süreçleri sizin adınıza, baştan sona takip ederiz. Dört temel başlıkta
        eksiksiz danışmanlık.
      </p>
    </header>

    <div class="services-grid">
      {
        services.map((s, i) => (
          <a class="service-card" href={`/hizmetler/${s.slug}/`} aria-label={`${s.name} hizmet detayı`}>
            <span class="service-num">{String(i + 1).padStart(2, "0")}</span>
            <span class="service-icon" aria-hidden="true" set:html={icons[s.slug] ?? ""} />
            <h3>{s.name}</h3>
            <p>{s.description}</p>
            <span class="service-card-go" aria-hidden="true">
              Detayı gör →
            </span>
          </a>
        ))
      }
    </div>

    <div class="services-foot">
      <p>Aradığınız hizmet hangisi olursa olsun — süreç tek elden yürür.</p>
      <a href="#iletisim" class="btn btn-primary">Danışmanlık alın</a>
    </div>
  </div>
</section>

<style>
  .section-services {
    background: var(--color-bg);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 720px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    display: block;
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 2.4rem 2.3rem 2.5rem;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-ink);
    transition:
      transform 0.25s var(--ease-out),
      box-shadow 0.25s,
      border-color 0.25s;
  }

  .service-card:hover {
    text-decoration: none;
    color: var(--color-ink);
  }

  .service-card-go {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--color-gold);
    transition: transform 0.2s var(--ease-out), color 0.2s;
  }

  .service-card:hover .service-card-go {
    transform: translateX(4px);
    color: var(--color-gold-deep);
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 3px;
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out);
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  /* Büyük filigran numara — sağ üstte, kartın derinliği */
  .service-num {
    position: absolute;
    top: 1.1rem;
    right: 1.6rem;
    font-family: var(--font-serif);
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-navy);
    opacity: 0.07;
    pointer-events: none;
  }

  .service-icon {
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    color: var(--color-gold);
    margin-bottom: 1.4rem;
    transition: border-color 0.25s, background 0.25s;
  }

  .service-icon :global(svg) {
    width: 26px;
    height: 26px;
    display: block;
  }

  .service-card:hover .service-icon {
    border-color: var(--color-gold);
    background: var(--color-gold-soft);
  }

  .service-card h3 {
    font-family: var(--font-serif);
    font-size: 1.42rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 0.65rem;
  }

  .service-card p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.66;
    color: var(--color-ink-muted);
    max-width: 42ch;
  }

  /* Alt kapanış — ifade + CTA */
  .services-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 1.6rem;
    margin-top: 2.5rem;
    padding-top: 2.25rem;
    border-top: 1px solid var(--color-line);
  }

  .services-foot p {
    margin: 0;
    font-size: 1.02rem;
    color: var(--color-ink);
    font-weight: 500;
  }
</style>
