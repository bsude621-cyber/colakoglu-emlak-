---
import { services } from "../data/config";
---

<section id="hizmetler" class="section section-alt">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">Ne sunuyoruz</p>
      <h2>Hizmetlerimiz</h2>
      <p class="section-desc">
        Gayrimenkulünüzün değerini doğru analiz eder, hukuki ve teknik
        süreçleri sizin adınıza takip ederiz.
      </p>
    </header>
    <div class="grid cards">
      {
        services.map((s) => (
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              {s.icon}
            </div>
            <h3>{s.name}</h3>
            <p>{s.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
