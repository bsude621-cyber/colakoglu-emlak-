---
import { site } from "../data/config";
// Kurucu (Ziya Ercan) bölümü — "01 Editorial Ivory" tasarımına göre yeniden kuruldu.
// Ivory editorial: Instrument Serif başlık + DM Mono etiket + sıcak kahve/altın.
// İçerik gerçek veriyle eşleşir (config + memory).

const roman = ["I", "II", "III", "IV", "V"];

const distinctions = [
  "Meslek odası başkanlığı — sektörel etik standartların belirleyicisi",
  "Ulusal federasyon temsilciliği — Türkiye genelinde tanınırlık",
  "Muğla'nın 8 ilçesinde yerel piyasa derinliği",
  "Yabancı yatırımcı süreçlerinde dil ve hukuk desteği",
];
---

<section id="hakkimizda" class="founder">
  <div class="founder-frame">
    <div class="founder-topbar">
      <span class="fmono">{site.name} — Muğla · est. {site.foundingYear}</span>
      <span class="fmono">Kurucu &amp; Vizyon</span>
    </div>

    <div class="founder-grid">
      <aside class="founder-aside">
        <span class="fmono founder-tag">01 — Kurucu</span>
        <figure class="founder-photo">
          <img
            src="/images/ziya-ercan-portre.jpg"
            alt="Ziya Ercan — Çolakoğlu Emlak Kurucusu"
            width="600"
            height="800"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <p class="founder-name">Ziya Ercan</p>
        <p class="fmono founder-name-sub">Kurucu · {site.name}</p>

        <blockquote class="founder-quote">
          <p>
            Bir emlakçı sadece konut göstermez — ailenin yıllarca yaşayacağı
            kararı şekillendirir. Bu sorumluluk, mesleğimizi sıradan bir
            ticaretten ayırır.
          </p>
          <cite>Ziya Ercan — Kurucu, {site.name}</cite>
        </blockquote>

        <div class="founder-stats">
          <div class="fstat">
            <span class="fstat-num">{site.experienceYears}</span>
            <span class="fmono fstat-label">Yıllık Tecrübe</span>
          </div>
          <div class="fstat">
            <span class="fstat-num">{site.memberships.length}</span>
            <span class="fmono fstat-label">Mesleki Temsil</span>
          </div>
          <div class="fstat">
            <span class="fstat-num">8</span>
            <span class="fmono fstat-label">İlçede Faaliyet</span>
          </div>
        </div>
      </aside>

      <div class="founder-main">
        <p class="fmono founder-eyebrow">{site.name} · Kurucu Notu</p>
        <h2 class="founder-title">
          Emlakçılıkta <em>güven</em> esastır.
        </h2>
        <p class="founder-lead">
          {site.name}, <strong>{site.foundingYear} yılında kurulan, Muğla'nın
          ilk emlak ofisidir.</strong> <strong>Ziya Ercan</strong> liderliğinde
          <strong>{site.experienceYears} yıllık tecrübeyle</strong> Muğla
          genelinde gayrimenkul danışmanlığı sunar. Bölgenin meslek odası,
          derneği ve ulusal federasyon temsilciliği bizde — bu, sıradan bir
          emlak ofisi değil, sektörün kendi temsilcisi anlamına gelir.
        </p>

        <a class="founder-link" href="/vizyon-misyon/">Vizyon ve misyonumuz →</a>

        <div class="founder-block">
          <p class="fmono founder-sub">Mesleki Liderlik</p>
          <ol class="founder-titles">
            {
              site.memberships.map((m, i) => (
                <li>
                  <span class="founder-rn">{roman[i]}</span>
                  <span class="founder-title-text">
                    <strong>{m.name}</strong>
                    <span class="fmono">{m.role}</span>
                  </span>
                </li>
              ))
            }
          </ol>
        </div>

        <div class="founder-block">
          <p class="fmono founder-sub">Bizi ayıran nitelikler</p>
          <ul class="founder-checks">
            {
              distinctions.map((d) => (
                <li>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4.5 12.6 9.5 17.5 19.5 6.5" />
                  </svg>
                  <span>{d}</span>
                </li>
              ))
            }
          </ul>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* "01 Editorial Ivory" — sıcak, klasik, Sotheby's-vari kurucu bölümü */
  /* Renkler sitenin paletiyle uyumlu — editorial düzen + Instrument Serif kalır */
  .founder {
    --f-bg: #ffffff;
    --f-bg-deep: #f0f0ed;
    --f-ink: #28323b;
    --f-ink-soft: #5d6873;
    --f-gold: #8a6347;
    --f-line: rgba(40, 54, 65, 0.14);
    --f-serif: "Instrument Serif", Georgia, serif;
    --f-mono: "DM Mono", ui-monospace, monospace;
    background: var(--f-bg);
    color: var(--f-ink);
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .founder-frame {
    width: min(1200px, 100% - 3rem);
    margin-inline: auto;
    border: 1px solid var(--f-line);
    padding: clamp(1.5rem, 3.2vw, 3rem);
  }

  .fmono {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--f-ink-soft);
  }

  .founder-topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--f-line);
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4.5vw, 4rem);
    padding-top: clamp(2rem, 4vw, 3.25rem);
    align-items: start;
  }

  /* --- Sol: portre --- */
  .founder-aside {
    display: flex;
    flex-direction: column;
  }

  .founder-tag {
    color: var(--f-gold);
    margin-bottom: 1rem;
  }

  .founder-photo {
    margin: 0;
    padding: 9px;
    background: var(--f-bg-deep);
    border: 1px solid var(--f-line);
  }

  .founder-photo img {
    display: block;
    width: 100%;
    height: clamp(400px, 62vh, 600px);
    object-fit: cover;
    object-position: center 18%;
    filter: grayscale(0.12) contrast(1.03);
  }

  .founder-name {
    font-family: var(--f-serif);
    font-style: italic;
    font-size: 2rem;
    line-height: 1;
    margin: 1.25rem 0 0.4rem;
    color: var(--f-ink);
  }

  .founder-name-sub {
    margin: 0;
    color: var(--f-gold);
  }

  .founder-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 1.75rem;
  }

  .fstat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 0.9rem 0 0;
    border-top: 1px solid var(--f-line);
  }

  .fstat-num {
    font-family: var(--f-serif);
    font-size: clamp(2.4rem, 4vw, 3.1rem);
    line-height: 0.85;
    color: var(--f-ink);
  }

  .fstat-label {
    font-size: 0.62rem;
    line-height: 1.35;
  }

  /* --- Sağ: içerik --- */
  .founder-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--f-gold);
    margin: 0 0 1.4rem;
  }

  .founder-eyebrow::before {
    content: "";
    width: 1.6rem;
    height: 1px;
    background: var(--f-gold);
  }

  .founder-title {
    font-family: var(--f-serif);
    font-weight: 400;
    font-size: clamp(2.7rem, 6vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: 0.005em;
    margin: 0 0 1.4rem;
    color: var(--f-ink);
  }

  .founder-title em {
    font-style: italic;
    color: var(--f-gold);
  }

  .founder-lead {
    font-size: 1.04rem;
    line-height: 1.7;
    color: var(--f-ink-soft);
    margin: 0 0 2.5rem;
    max-width: 44ch;
  }

  .founder-lead strong {
    color: var(--f-ink);
    font-weight: 600;
  }

  .founder-link {
    display: inline-flex;
    align-items: center;
    margin: 0 0 2.25rem;
    font-family: var(--f-mono);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--f-gold);
    text-decoration: none;
    border-bottom: 1px solid var(--f-line);
    padding-bottom: 0.25rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .founder-link:hover {
    color: var(--f-ink);
    border-color: var(--f-gold);
  }

  .founder-block {
    margin-bottom: 2.25rem;
  }

  .founder-sub {
    margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--f-line);
    color: var(--f-ink);
  }

  /* Numaralı unvan listesi */
  .founder-titles {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .founder-titles li {
    display: grid;
    grid-template-columns: 2.4rem 1fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--f-line);
  }

  .founder-titles li:last-child {
    border-bottom: none;
  }

  .founder-rn {
    font-family: var(--f-serif);
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.1;
    color: var(--f-gold);
  }

  .founder-title-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .founder-title-text strong {
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--f-ink);
    line-height: 1.35;
  }

  /* Çek listesi */
  .founder-checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 1.6rem;
  }

  .founder-checks li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--f-ink-soft);
  }

  .founder-checks svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--f-gold);
  }

  /* Alıntı */
  .founder-quote {
    margin: 1.75rem 0 0;
    padding: 1.5rem 1.65rem;
    background: var(--f-bg-deep);
    border-left: 2px solid var(--f-gold);
  }

  .founder-quote p {
    font-family: var(--f-serif);
    font-size: 1.3rem;
    line-height: 1.34;
    margin: 0 0 0.9rem;
    color: var(--f-ink);
  }

  .founder-quote cite {
    font-family: var(--f-mono);
    font-style: normal;
    font-size: 0.7rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--f-gold);
  }

  @media (max-width: 820px) {
    .founder-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .founder-photo img {
      height: clamp(380px, 58vh, 520px);
    }

    .founder-checks {
      grid-template-columns: 1fr;
    }

    .founder-topbar .fmono:last-child {
      display: none;
    }
  }

  @media (max-width: 460px) {
    .founder-stats {
      grid-template-columns: 1fr;
    }

    .fstat {
      flex-direction: row;
      align-items: baseline;
      gap: 0.7rem;
      padding-bottom: 0.6rem;
    }
  }
</style>
