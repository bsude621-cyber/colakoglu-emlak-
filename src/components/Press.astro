---
// Basında Biz — gazete-kupürü estetiği.
// Yayın adı masthead + ince kural çizgisi + manşet (editoryal serif) +
// tarih damgası (mono). Görsel yok; haber hissi tipografiyle verilir.
// İçerik kuralı: yalnızca doğrulanmış gerçek haberler — veri src/data/press.ts.
import { press } from "../data/press";
---

<section
  class="section section-press"
  id="basinda"
  aria-labelledby="basinda-baslik"
>
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Basında Biz</p>
      <h2 id="basinda-baslik">Basında Çolakoğlu Emlak</h2>
      <p class="section-desc">
        Ziya Ercan ve Çolakoğlu Emlak'ın yerel basın, ulusal sektör yayınları
        ve resmî kurumların gündeminde yer aldığı haberler.
      </p>
    </div>

    <ul class="press-list">
      {
        press.map((item) => (
          <li>
            <a
              class="press-cut"
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="press-cut-folio">
                <span class="press-cut-outlet">{item.outlet}</span>
                <span class="press-cut-date">{item.dateLabel}</span>
              </span>
              <h3 class="press-cut-headline">{item.title}</h3>
              {item.excerpt && (
                <p class="press-cut-excerpt">{item.excerpt}</p>
              )}
              <span class="press-cut-cta">
                Habere git
                <svg
                  viewBox="0 0 24 24"
                  width="14"
                  height="14"
                  aria-hidden="true"
                >
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M7 17 17 7M9 7h8v8"
                  />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="press-note">
      Haber içerikleri ilgili yayın organlarına aittir; bağlantılar orijinal
      kaynağa yönlendirir.
    </p>
  </div>
</section>

<style>
  .section-press {
    background: var(--color-bg);
  }

  .press-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 720px) {
    .press-list {
      grid-template-columns: 1fr;
    }
  }

  /* Gazete kupürü */
  .press-cut {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem 1.65rem 1.7rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      transform 0.25s var(--ease-out),
      box-shadow 0.25s,
      border-color 0.25s;
  }

  .press-cut:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  /* Folyo satırı — yayın adı (masthead) + tarih, altında kural çizgisi */
  .press-cut-folio {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.7rem;
    margin-bottom: 0.95rem;
    border-bottom: 1.5px solid var(--color-ink);
  }

  .press-cut-outlet {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .press-cut-date {
    flex-shrink: 0;
    font-family: ui-monospace, "SF Mono", "Cascadia Mono", Menlo, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .press-cut-headline {
    font-family: Georgia, "Times New Roman", "Cambria Math", Cambria, serif;
    font-size: clamp(1.4rem, 2.2vw, 1.7rem);
    font-weight: 400;
    line-height: 1.16;
    letter-spacing: 0.005em;
    color: var(--color-ink);
    margin: 0 0 0.7rem;
    text-wrap: balance;
  }

  .press-cut-excerpt {
    margin: 0 0 1.2rem;
    font-size: 0.93rem;
    line-height: 1.62;
    color: var(--color-ink-muted);
  }

  .press-cut-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .press-cut-cta svg {
    transition: transform 0.2s var(--ease-out);
  }

  .press-cut:hover .press-cut-cta {
    color: var(--color-gold-deep);
  }

  .press-cut:hover .press-cut-cta svg {
    transform: translate(2px, -2px);
  }

  .press-note {
    margin: 2rem 0 0;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    text-align: center;
  }
</style>
