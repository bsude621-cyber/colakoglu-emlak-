---
// Mesleki üyelikler bandı — TEMFED + Muğla Emlak Danışmanları Esnaf Odası logoları.
// Bu bant otorite sinyali olarak About bölümünden hemen sonra gösterilir.
// Schema'da memberOf entity'leri ile birebir eşleşir.
import { site } from "../data/config";
---

<section class="memberships" aria-label="Mesleki üyelikler">
  <div class="container">
    <p class="memberships-title">
      Sektörel temsil ve mesleki üyelikler
    </p>

    <div class="memberships-grid">
      <div class="membership-card">
        <span class="membership-card-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5.5"/><path d="M8.4 13.3 6.5 21l5.5-3 5.5 3-1.9-7.7"/></svg></span>
        <div class="membership-card-body">
          <p class="membership-card-role">Başkan</p>
          <h3>Muğla Emlak Danışmanları Esnaf Odası</h3>
          <p class="membership-card-note">
            Muğla ili emlak danışmanlarının yasal meslek temsilcisi
          </p>
        </div>
      </div>

      <div class="membership-card">
        <span class="membership-card-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5.5"/><path d="M8.4 13.3 6.5 21l5.5-3 5.5 3-1.9-7.7"/></svg></span>
        <div class="membership-card-body">
          <p class="membership-card-role">Başkan</p>
          <h3>Muğla Emlak Müşavirleri Derneği</h3>
          <p class="membership-card-note">
            Bölgesel emlak müşavirlerinin mesleki birliği
          </p>
        </div>
      </div>

      <div class="membership-card membership-card--highlight">
        <span class="membership-card-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5.5"/><path d="M8.4 13.3 6.5 21l5.5-3 5.5 3-1.9-7.7"/></svg></span>
        <div class="membership-card-body">
          <p class="membership-card-role">Genel Başkan Yardımcısı</p>
          <h3>TEMFED</h3>
          <p class="membership-card-note">
            Türkiye Tüm Emlak Müşavirleri Federasyonu — ulusal sektörel temsil
          </p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .memberships {
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .memberships-title {
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    font-weight: 600;
    margin: 0 0 2.5rem;
  }

  .memberships-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .memberships-grid {
      grid-template-columns: 1fr;
    }
  }

  .membership-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition:
      transform 0.25s var(--ease-out),
      border-color 0.25s,
      box-shadow 0.25s;
  }

  .membership-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-navy);
    box-shadow: var(--shadow-soft);
  }

  /* TEMFED — vurgulu kart, lacivert dolu blok */
  .membership-card--highlight {
    background: var(--color-navy);
    border-color: var(--color-navy);
  }

  .membership-card-mark {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    background: var(--color-gold);
    color: #fff;
  }

  .membership-card-mark svg {
    width: 21px;
    height: 21px;
  }

  .membership-card--highlight .membership-card-mark {
    background: var(--color-gold-bright);
  }

  .membership-card-role {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 0.3rem;
    font-weight: 700;
  }

  .membership-card-body h3 {
    font-family: var(--font-serif);
    font-size: 1.18rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
    color: var(--color-ink);
    line-height: 1.25;
  }

  .membership-card-note {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.5;
  }

  .membership-card--highlight .membership-card-role {
    color: var(--color-gold-bright);
  }

  .membership-card--highlight .membership-card-body h3 {
    color: #fff;
  }

  .membership-card--highlight .membership-card-note {
    color: rgba(255, 255, 255, 0.72);
  }

</style>
