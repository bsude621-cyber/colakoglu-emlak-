---
// Mesleki otorite bölümü — Ziya Ercan'ın 3 federasyon/oda/dernek konumu.
// Koyu zemin: otorite ağırlığı + görsel ritim. Schema memberOf ile eşleşir.
const memberships = [
  {
    role: "Başkan",
    name: "Muğla Emlak Danışmanları Esnaf Odası",
    note: "Muğla ili emlak danışmanlarının yasal meslek temsilcisi.",
  },
  {
    role: "Başkan",
    name: "Muğla Emlak Müşavirleri Derneği",
    note: "Bölgenin emlak müşavirlerini bir araya getiren mesleki birlik.",
  },
  {
    role: "Genel Başkan Yardımcısı",
    name: "TEMFED — Türkiye Tüm Emlak Müşavirleri Federasyonu",
    note: "Ulusal düzeyde sektörel temsil ve meslek standardı.",
    highlight: true,
  },
];
---

<section class="section section-memberships" aria-labelledby="uyelik-baslik">
  <div class="container">
    <header class="section-head section-head-center memberships-head">
      <p class="eyebrow">Mesleki Otorite</p>
      <h2 id="uyelik-baslik">Muğla emlak sektörünün yasal meslek temsilcisi</h2>
      <p class="section-desc">
        Ziya Ercan, Muğla emlak sektöründe üç mesleki temsil konumunu birden
        taşıyor: ilin esnaf odası başkanlığı, müşavirler derneği başkanlığı ve
        ulusal federasyon genel başkan yardımcılığı.
      </p>
    </header>

    <div class="memberships-grid">
      {
        memberships.map((m) => (
          <article class={`mem-card${m.highlight ? " mem-card--lead" : ""}`}>
            <span class="mem-card-mark" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="22"
                height="22"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="9" r="5.5" />
                <path d="M8.4 13.3 6.5 21l5.5-3 5.5 3-1.9-7.7" />
              </svg>
            </span>
            <p class="mem-card-role">{m.role}</p>
            <h3>{m.name}</h3>
            <p class="mem-card-note">{m.note}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-memberships {
    background: var(--color-wood-deep, #1e2a34);
  }

  .memberships-head .eyebrow {
    color: var(--color-gold-bright);
  }

  .memberships-head h2 {
    color: #fff;
  }

  .memberships-head .section-desc {
    color: rgba(255, 255, 255, 0.7);
  }

  .memberships-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 860px) {
    .memberships-grid {
      grid-template-columns: 1fr;
    }
  }

  .mem-card {
    display: flex;
    flex-direction: column;
    padding: 1.9rem 1.8rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition:
      transform 0.25s var(--ease-out),
      border-color 0.25s,
      background 0.25s;
  }

  .mem-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  /* TEMFED — ulusal konum, altın vurgulu */
  .mem-card--lead {
    border-color: rgba(168, 127, 94, 0.5);
    background: rgba(168, 127, 94, 0.09);
  }

  .mem-card--lead:hover {
    border-color: var(--color-gold);
    background: rgba(168, 127, 94, 0.13);
  }

  .mem-card-mark {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(168, 127, 94, 0.16);
    color: var(--color-gold-bright);
    margin-bottom: 1.2rem;
  }

  .mem-card--lead .mem-card-mark {
    background: var(--color-gold);
    color: #fff;
  }

  .mem-card-role {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold-bright);
    margin: 0 0 0.5rem;
  }

  .mem-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: #fff;
    margin: 0 0 0.7rem;
  }

  .mem-card-note {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
  }
</style>
