---
import { site } from "../data/config";

// Form Web3Forms ile backend'siz çalışır.
// [[BİLGİ GEREK: Web3Forms access_key — Sude oluşturup .env'e koyacak (PUBLIC_WEB3FORMS_KEY)]]
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";
const hasFormKey = accessKey !== "YOUR_ACCESS_KEY_HERE";
---

<section id="iletisim" class="section section-contact section-contact-dark">
  <div class="container contact-grid">
    <div class="contact-intro">
      <p class="eyebrow">İletişim</p>
      <h2>Bir kahve içmeye bekleriz</h2>
      <p class="section-desc">
        Gayrimenkulünüzü değerlendirmek veya aradığınızı birlikte netleştirmek
        için {hasFormKey ? "arayın, yazın ya da formu doldurun" : "arayın veya WhatsApp'tan yazın"} — en kısa sürede dönüş yapalım.
      </p>

      <address class="contact-block">
        <p>
          <strong>Sahibi</strong><br />
          Ziya Ercan
        </p>
        <p class="contact-block-address">
          <strong>Ofis adresi</strong><br />
          {site.address.street},<br />
          {site.address.locality}/{site.address.region}
        </p>
        <p>
          <strong>İş telefonu</strong><br />
          <a href={`tel:${site.contact.phone}`}>{site.contact.phoneDisplay}</a>
        </p>
        <p>
          <strong>GSM</strong><br />
          <a href={`tel:${site.contact.mobile}`}>{site.contact.mobileDisplay}</a>
        </p>
        {site.contact.email && (
          <p>
            <strong>E-posta</strong><br />
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </p>
        )}
        {site.contact.whatsapp && (
          <p>
            <strong>WhatsApp</strong><br />
            <a
              href={`https://wa.me/${site.contact.whatsapp}`}
              target="_blank"
              rel="noopener"
            >
              {site.contact.mobileDisplay}
            </a>
          </p>
        )}
      </address>

      <div class="trust-badges">
        <p class="trust-badges-title">Mesleki üyelikler</p>
        <ul>
          {site.memberships.map((m) => (
            <li>
              <strong>{m.role}</strong> — {m.name}
            </li>
          ))}
        </ul>
      </div>

      <!-- Harita — yerel pack + Knowledge Panel için zorunlu sinyal -->
      <figure class="contact-map">
        <iframe
          src={`https://maps.google.com/maps?q=${site.geo.latitude},${site.geo.longitude}&hl=tr&z=16&output=embed`}
          title={`${site.name} — ofis konumu, ${site.address.locality}/${site.address.region}`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
        <figcaption>
          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${site.geo.latitude},${site.geo.longitude}`}
            target="_blank"
            rel="noopener"
          >
            Yol tarifi al →
          </a>
        </figcaption>
      </figure>
    </div>

    {hasFormKey ? (
    <form
      class="contact-form"
      data-contact-form
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value={accessKey} />
      <input
        type="hidden"
        name="subject"
        value="Çolakoğlu Emlak — Yeni iletişim formu"
      />
      <input
        type="hidden"
        name="from_name"
        value="Çolakoğlu Emlak Web Sitesi"
      />
      <input
        type="checkbox"
        name="botcheck"
        class="visually-hidden"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        aria-label="Bot kontrolü — boş bırakın"
      />
      <label>
        <span>Ad Soyad</span>
        <input
          type="text"
          name="name"
          required
          autocomplete="name"
          placeholder="Adınız Soyadınız"
        />
      </label>
      <label>
        <span>Telefon</span>
        <input
          type="tel"
          name="phone"
          required
          autocomplete="tel"
          placeholder="05xx xxx xx xx"
        />
      </label>

      <details class="form-extra">
        <summary>
          <span>Daha hızlı dönüş için (opsiyonel)</span>
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
            <path
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 9l6 6 6-6"
            ></path>
          </svg>
        </summary>
        <label>
          <span>E-posta</span>
          <input
            type="email"
            name="email"
            autocomplete="email"
            placeholder="ornek@eposta.com"
          />
        </label>
        <label>
          <span>İlgi alanı</span>
          <select name="interest">
            <option value="">Seçiniz</option>
            <option>Satılık konut</option>
            <option>Kiralık konut</option>
            <option>Arsa / arazi</option>
            <option>Ticari</option>
            <option>Değerleme</option>
            <option>Yatırım danışmanlığı</option>
          </select>
        </label>
        <label>
          <span>Bölge</span>
          <select name="region">
            <option value="">Seçiniz</option>
            <option>Bodrum</option>
            <option>Marmaris</option>
            <option>Fethiye</option>
            <option>Milas</option>
            <option>Datça</option>
            <option>Köyceğiz</option>
            <option>Ortaca</option>
            <option>Dalaman</option>
            <option>Menteşe</option>
            <option>Ula</option>
            <option>Yatağan</option>
            <option>Kavaklıdere</option>
            <option>Seydikemer</option>
            <option>Muğla geneli</option>
          </select>
        </label>
        <label>
          <span>Mesajınız</span>
          <textarea
            name="message"
            rows="4"
            placeholder="Bütçe, lokasyon ve zaman çizelgeniz..."></textarea>
        </label>
      </details>

      <button type="submit" class="btn btn-primary btn-block">Gönder</button>
      <p class="form-hint" data-form-status role="status" aria-live="polite"></p>
    </form>
    ) : (
    <div class="contact-form contact-placeholder">
      <p class="placeholder-eyebrow">İletişim Formu</p>
      <h3>Şimdilik en hızlı yol — doğrudan ulaşın</h3>
      <p>
        İletişim formunu çok yakında açıyoruz. Bugün için telefon veya
        WhatsApp ile dakikalar içinde dönüş alırsınız.
      </p>
      <a
        href={`tel:${site.contact.phone}`}
        class="btn btn-primary btn-block"
      >
        {site.contact.phoneDisplay}
      </a>
      <a
        href={`https://wa.me/${site.contact.whatsapp}`}
        class="btn btn-ghost btn-block placeholder-wa"
        target="_blank"
        rel="noopener"
      >
        WhatsApp ile yazın
      </a>
    </div>
    )}
  </div>
</section>

<style>
  /* Koyu kapanış bölümü — sayfa güçlü biter, beyaz form kartı öne çıkar */
  .section-contact-dark {
    background: var(--color-navy);
  }

  .contact-grid {
    align-items: start;
  }

  .section-contact-dark .eyebrow {
    color: var(--color-gold-bright);
  }

  .section-contact-dark h2 {
    color: #fff;
  }

  .section-contact-dark .section-desc {
    color: rgba(255, 255, 255, 0.72);
    max-width: 34ch;
  }

  .contact-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem 1.5rem;
    margin-top: 2rem;
  }

  .contact-block p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
  }

  .contact-block strong {
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold-bright);
  }

  .contact-block a {
    color: #fff;
    font-weight: 600;
    text-decoration: none;
  }

  .contact-block a:hover {
    color: var(--color-gold-bright);
    text-decoration: none;
  }

  .trust-badges {
    margin-top: 1.9rem;
    padding: 1.4rem 1.5rem;
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
  }

  .trust-badges-title {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-bright);
    margin: 0 0 0.85rem;
    font-weight: 700;
  }

  .trust-badges ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .trust-badges li {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.74);
    padding-left: 0.9rem;
    border-left: 2px solid var(--color-gold);
  }

  .trust-badges strong {
    display: block;
    color: #fff;
    font-weight: 600;
    font-size: 0.86rem;
  }

  /* Adres satırı — kolonun tam genişliği (telefon/GSM gibi tek-line değil) */
  .contact-block-address {
    grid-column: 1 / -1;
  }

  /* Harita — yerel pack + Knowledge Panel için zorunlu sinyal */
  .contact-map {
    margin: 1.85rem 0 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.04);
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 280px;
    border: 0;
    filter: grayscale(0.15) contrast(1.05);
  }

  .contact-map figcaption {
    padding: 0.75rem 1.1rem;
    background: rgba(0, 0, 0, 0.2);
    font-size: 0.85rem;
  }

  .contact-map figcaption a {
    color: var(--color-gold-bright);
    font-weight: 600;
    text-decoration: none;
  }

  .contact-map figcaption a:hover {
    color: #fff;
  }

  /* Beyaz form kartı koyu zeminde — derin gölge ile öne çıkar */
  .section-contact-dark .contact-form {
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  /* Form sadeleştirme — sadece Ad + Telefon zorunlu görünür, 4 opsiyonel alan
     <details> içinde gizli. Hick's Law: ilk temas karar yükünü azalt. */
  .form-extra {
    margin: 0;
  }

  .form-extra > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.75rem 0;
    cursor: pointer;
    list-style: none;
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    border-top: 1px dashed rgba(0, 0, 0, 0.12);
    border-bottom: 1px dashed rgba(0, 0, 0, 0.12);
    transition: color 0.2s;
  }

  .form-extra > summary::-webkit-details-marker {
    display: none;
  }

  .form-extra > summary:hover {
    color: var(--color-ink);
  }

  .form-extra > summary svg {
    flex-shrink: 0;
    transition: transform 0.25s var(--ease-out);
  }

  .form-extra[open] > summary svg {
    transform: rotate(180deg);
  }

  .form-extra[open] > summary {
    margin-bottom: 0.6rem;
    border-bottom-style: solid;
    color: var(--color-ink);
  }

  .form-extra > label {
    margin-top: 0.75rem;
  }

  /* Form key gelene kadar placeholder — telefon + WhatsApp öne */
  .contact-placeholder {
    gap: 1rem;
  }

  .contact-placeholder .placeholder-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    font-weight: 700;
    margin: 0;
  }

  .contact-placeholder h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.2vw, 1.55rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
    text-wrap: balance;
  }

  .contact-placeholder p {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  .contact-placeholder .placeholder-wa {
    background: var(--color-surface);
    color: var(--color-ink);
    border: 1px solid var(--color-navy);
  }

  .contact-placeholder .placeholder-wa:hover {
    background: var(--color-navy);
    color: #fff;
  }

  @media (max-width: 540px) {
    .contact-block {
      grid-template-columns: 1fr;
      gap: 0.95rem;
    }
  }
</style>
