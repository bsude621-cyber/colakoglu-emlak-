---
// Süreç — Çolakoğlu Emlak danışmanlık akışı.
// Koyu bölüm + bağlı dikey zaman çizgisi: süreç bir "yolculuk" gibi okunur.
// [[BİLGİ GEREK: Ziya Ercan onayı ile özelleştirilecek — gerçek süreç farklıysa
// adımlar yeniden yazılacak]]
const steps = [
  {
    number: "01",
    title: "Tanışma",
    description:
      "İlk görüşmede ihtiyacınızı, beklentinizi ve bütçenizi dinleriz. Alıcı veya satıcı olun, doğru sorularla resmi netleştiririz. Telefon, ofis veya sahada — sizin için uygun yerde.",
    duration: "~30 dakika",
  },
  {
    number: "02",
    title: "Saha ve piyasa analizi",
    description:
      "Aradığınız bölgede güncel piyasa verilerini, benzer satışları ve fiyat trendlerini paylaşırız. Satıcıysanız gayrimenkulünüz için piyasa karşılaştırmalı değerleme raporu hazırlarız.",
    duration: "1-3 gün",
  },
  {
    number: "03",
    title: "Eşleştirme ve görüntüleme",
    description:
      "Geniş bayi ağımızdan size uygun seçenekleri filtreleriz. Sahada eşlik eder, tapu/imar/yapı durumunu yerinde inceleriz. Yabancı yatırımcılara dil desteği veririz.",
    duration: "süreç boyunca",
  },
  {
    number: "04",
    title: "Hukuki süreç ve teslim",
    description:
      "Tapu, vergi, sözleşme aşamalarında güvenilir hukuk ve mali müşavir iş ortaklarıyla koordineli ilerleriz. Teslim sonrası danışmanlık desteği devam eder.",
    duration: "1-4 hafta",
  },
];
---

<section id="surec" class="section section-process">
  <div class="container">
    <header class="section-head section-head-center process-head">
      <p class="eyebrow">Nasıl Çalışıyoruz</p>
      <h2>Çolakoğlu Emlak süreci</h2>
      <p class="section-desc">
        Şeffaf, ölçülebilir ve baştan sona eşlikli bir süreç. Hangi adımda
        olduğunuzu hep bilirsiniz — sürpriz yok.
      </p>
    </header>

    <ol class="process-timeline">
      {
        steps.map((step) => (
          <li class="process-step">
            <div class="process-step-rail">
              <span class="process-step-node">{step.number}</span>
            </div>
            <div class="process-step-body">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
              <p class="process-step-duration">
                <svg
                  viewBox="0 0 24 24"
                  width="14"
                  height="14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="8.5" />
                  <path d="M12 7.6V12l3.1 2.2" />
                </svg>
                {step.duration}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section-process {
    background: var(--color-wood-deep, #1e2a34);
  }

  .process-head .eyebrow {
    color: var(--color-gold-bright);
  }

  .process-head h2 {
    color: #fff;
  }

  .process-head .section-desc {
    color: rgba(255, 255, 255, 0.7);
  }

  .process-timeline {
    position: relative;
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }

  /* Bağlı zaman çizgisi — düğümlerin ortasından geçer */
  .process-timeline::before {
    content: "";
    position: absolute;
    left: 31px;
    top: 31px;
    bottom: 31px;
    width: 2px;
    transform: translateX(-1px);
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(168, 127, 94, 0.55) 9%,
      rgba(168, 127, 94, 0.55) 91%,
      transparent 100%
    );
  }

  .process-step {
    display: grid;
    grid-template-columns: 62px 1fr;
    gap: 1.6rem;
    align-items: start;
  }

  .process-step-rail {
    width: 62px;
  }

  .process-step-node {
    position: relative;
    z-index: 1;
    width: 62px;
    height: 62px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--color-navy);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-gold-bright);
    transition:
      border-color 0.25s var(--ease-out),
      transform 0.25s var(--ease-out);
  }

  .process-step:hover .process-step-node {
    border-color: var(--color-gold);
    transform: scale(1.06);
  }

  .process-step-body {
    padding-top: 0.35rem;
  }

  .process-step-body h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .process-step-body p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.62;
    color: rgba(255, 255, 255, 0.7);
  }

  .process-step-duration {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem !important;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-gold-bright) !important;
  }

  @media (max-width: 560px) {
    .process-timeline::before {
      left: 25px;
    }

    .process-step {
      grid-template-columns: 50px 1fr;
      gap: 1.1rem;
    }

    .process-step-rail {
      width: 50px;
    }

    .process-step-node {
      width: 50px;
      height: 50px;
      font-size: 1.1rem;
    }
  }
</style>
