---
// Sinematik hero — scroll'a bağlı canvas image-sequence ("Varış").
// Kullanıcı kaydırdıkça 87 karelik altın-saat sahil çekimi oynar.
// modusprojects.nl tekniği. Mobil + reduced-motion: tek statik kare (sekans inmez).
import { site } from "../data/config";

const FRAME_COUNT = 87;
const telHref = `tel:${site.contact.phone.replace(/[^+\d]/g, "")}`;
---

<section class="hero-cine" id="acilis" data-hero-cine data-frames={FRAME_COUNT}>
  <div class="hero-cine__viewport">
    <img
      class="hero-cine__poster"
      src="/images/hero/frame-001.webp"
      alt="Muğla sahili — gün batımında Ege kıyısı"
      width="1440"
      height="810"
      fetchpriority="high"
      decoding="async"
    />
    <canvas class="hero-cine__canvas" data-hero-canvas aria-hidden="true"></canvas>
    <div class="hero-cine__scrim" aria-hidden="true"></div>

    <div class="container hero-cine__content">
      <div class="experience-badge" aria-label="32 yıllık sektör tecrübesi">
        <span class="experience-badge__year">32+</span>
        <span class="experience-badge__label">
          <span>Yıllık</span>
          <span>Tecrübe</span>
        </span>
      </div>
      <p class="hero-cine__kicker">
        <span class="hero-cine__tick" aria-hidden="true"></span>
        Muğla'nın ilk emlak ofisi · 1994'ten beri
      </p>
      <h1 class="hero-cine__title">Çolakoğlu Emlak</h1>
      <p class="hero-cine__slogan">“Emlakçılıkta Güven Esastır”</p>
      <p class="hero-cine__lede">
        Ziya Ercan liderliğinde 32 yıldır — Muğla genelinde alım, satım,
        kiralama ve değerleme danışmanlığı.
      </p>
      <div class="hero-cine__actions">
        <a href="#iletisim" class="btn btn-primary">Danışmanlık alın</a>
        <a href={telHref} class="btn hero-cine__btn-line">
          <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true">
            <path
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.5 3.5h3l1.5 4-2 1.5a12 12 0 0 0 5.5 5.5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16.5 16.5 0 0 1 4.5 5.7 2 2 0 0 1 6.5 3.5Z"
            ></path>
          </svg>
          {site.contact.phoneDisplay}
        </a>
      </div>
    </div>

    <div class="hero-cine__hint" aria-hidden="true">
      <span>Keşfet</span>
      <span class="hero-cine__hint-line"></span>
    </div>
  </div>
</section>

<style>
  /* Varsayılan: tek ekran statik (no-JS / mobil / reduced-motion güvenli) */
  .hero-cine {
    position: relative;
    height: 100svh;
    background: var(--color-wood-deep, #1e2a34);
  }

  /* JS + masaüstü + motion-OK: uzun scroll bölümü → sekans scrub */
  .hero-cine--scrub {
    height: 320vh;
  }

  .hero-cine__viewport {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
  }

  .hero-cine__poster,
  .hero-cine__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .hero-cine__poster {
    z-index: 1;
  }

  .hero-cine__canvas {
    z-index: 2;
    opacity: 0;
    transition: opacity 0.5s var(--ease-out);
  }

  .hero-cine__canvas.is-ready {
    opacity: 1;
  }

  .hero-cine--static .hero-cine__canvas {
    display: none;
  }

  /* Metin okunurluğu — lacivert tonlu sinematik perde */
  .hero-cine__scrim {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(18, 24, 32, 0.55) 0%,
        rgba(18, 24, 32, 0.12) 26%,
        rgba(18, 24, 32, 0.28) 60%,
        rgba(14, 19, 26, 0.86) 100%
      ),
      linear-gradient(
        92deg,
        rgba(14, 19, 26, 0.62) 0%,
        rgba(14, 19, 26, 0.16) 46%,
        rgba(14, 19, 26, 0) 72%
      );
  }

  .hero-cine__content {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 4;
    padding-bottom: clamp(3.5rem, 8vh, 6rem);
    padding-top: var(--header-h);
  }

  /* Tecrübe rozeti */
  .experience-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.95rem;
    margin: 0 0 1.5rem;
  }

  .experience-badge__year {
    font-family: var(--font-serif);
    font-size: 2.7rem;
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .experience-badge__label {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    border-left: 2px solid var(--color-gold-bright);
    padding-left: 0.9rem;
  }

  .experience-badge__label > span:last-child {
    text-transform: none;
    letter-spacing: 0.02em;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero-cine__kicker {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0 0 1.1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold-bright);
  }

  .hero-cine__tick {
    width: 1.9rem;
    height: 2px;
    background: var(--color-gold-bright);
    flex-shrink: 0;
  }

  .hero-cine__title {
    font-family: var(--font-serif);
    font-size: clamp(2.9rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: #fff;
    margin: 0 0 0.9rem;
    text-shadow: 0 2px 30px rgba(12, 18, 24, 0.5);
    text-wrap: balance;
  }

  .hero-cine__slogan {
    font-size: clamp(1.05rem, 2.2vw, 1.4rem);
    font-weight: 500;
    color: var(--color-gold-bright);
    margin: 0 0 1.15rem;
  }

  .hero-cine__lede {
    max-width: 34rem;
    font-size: clamp(1rem, 1.4vw, 1.12rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.86);
    margin: 0 0 2rem;
  }

  .hero-cine__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-cine__btn-line {
    gap: 0.55rem;
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(6px);
  }

  .hero-cine__btn-line:hover {
    background: rgba(255, 255, 255, 0.16);
    border-color: #fff;
    color: #fff;
  }

  /* Scroll ipucu */
  .hero-cine__hint {
    position: absolute;
    left: 50%;
    bottom: 1.4rem;
    z-index: 4;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
  }

  .hero-cine__hint-line {
    width: 1px;
    height: 38px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), transparent);
    animation: hint-pulse 2.2s ease-in-out infinite;
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 0.35; transform: scaleY(0.8); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); transform-origin: top; }
  }

  /* Statik modda scroll ipucu gizlenir (scrub yok) */
  .hero-cine--static .hero-cine__hint {
    display: none;
  }

  /* İçerik giriş animasyonu */
  .hero-cine__content > * {
    animation: cine-in 0.8s var(--ease-out) both;
  }
  .experience-badge { animation-delay: 0.15s; }
  .hero-cine__kicker { animation-delay: 0.25s; }
  .hero-cine__title { animation-delay: 0.35s; }
  .hero-cine__slogan { animation-delay: 0.45s; }
  .hero-cine__lede { animation-delay: 0.55s; }
  .hero-cine__actions { animation-delay: 0.65s; }

  @keyframes cine-in {
    from { opacity: 0; transform: translateY(26px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cine__content > * { animation: none; }
    .hero-cine__hint-line { animation: none; }
    .hero-cine__canvas { transition: none; }
  }

  @media (max-width: 560px) {
    .hero-cine__hint { display: none; }
  }
</style>

<script>
  (function () {
    var section = document.querySelector("[data-hero-cine]");
    if (!section) return;
    var canvas = section.querySelector("[data-hero-canvas]");
    var FRAMES = parseInt(section.getAttribute("data-frames"), 10) || 87;

    var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    var small = matchMedia("(max-width: 800px)").matches;

    // Mobil / reduced-motion: sekans inmez, statik poster kalır.
    if (reduce || small || !canvas || !canvas.getContext) {
      section.classList.add("hero-cine--static");
      return;
    }

    section.classList.add("hero-cine--scrub");
    var ctx = canvas.getContext("2d");
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var images = new Array(FRAMES);
    var current = -1;

    function frameUrl(i) {
      return "/images/hero/frame-" + String(i + 1).padStart(3, "0") + ".webp";
    }

    function drawFrame(i, force) {
      if ((i === current && !force) || i < 0) return;
      var img = images[i];
      if (!img || !img.complete || !img.naturalWidth) return;
      current = i;
      var cw = canvas.width, ch = canvas.height;
      var iw = img.naturalWidth, ih = img.naturalHeight;
      var scale = Math.max(cw / iw, ch / ih);
      var w = iw * scale, h = ih * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
    }

    function sizeCanvas() {
      var r = canvas.getBoundingClientRect();
      canvas.width = Math.round(r.width * dpr);
      canvas.height = Math.round(r.height * dpr);
      drawFrame(current < 0 ? 0 : current, true);
    }

    function frameForScroll() {
      var rect = section.getBoundingClientRect();
      var total = section.offsetHeight - window.innerHeight;
      if (total <= 0) return 0;
      var p = Math.min(1, Math.max(0, -rect.top / total));
      return Math.min(FRAMES - 1, Math.round(p * (FRAMES - 1)));
    }

    var ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        drawFrame(frameForScroll());
        ticking = false;
      });
    }

    // Kareleri yükle — ilk kare gelince canvas'ı hazırla.
    for (var i = 0; i < FRAMES; i++) {
      (function (idx) {
        var img = new Image();
        img.onload = function () {
          if (idx === 0) {
            sizeCanvas();
            drawFrame(0, true);
            canvas.classList.add("is-ready");
          } else if (idx === current + 1) {
            drawFrame(frameForScroll());
          }
        };
        img.src = frameUrl(idx);
        images[idx] = img;
      })(i);
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", sizeCanvas);
  })();
</script>
