---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { neighborhoods, type Neighborhood } from "../../../data/neighborhoods";
import { regions } from "../../../data/regions";
import { site } from "../../../data/config";

export async function getStaticPaths() {
  return neighborhoods.map((n) => ({
    params: { ilce: n.parent, mahalle: n.slug },
    props: { neighborhood: n },
  }));
}

interface Props {
  neighborhood: Neighborhood;
}

const { neighborhood: nb } = Astro.props;
const title = `${nb.fullName} | ${nb.parentName} | ${site.name}`;
const description = nb.tldr.slice(0, 155);
const canonical = `${site.url}/bolgeler/${nb.parent}/${nb.slug}/`;

const parentRegion = regions.find((r) => r.slug === nb.parent);
const heroImage = `/images/ilce-${nb.parent}.webp?v=4`;

const siblingNeighborhoods = neighborhoods.filter(
  (n) => n.parent === nb.parent && n.slug !== nb.slug,
);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Bölgeler", item: `${site.url}/#bolgeler` },
    {
      "@type": "ListItem",
      position: 3,
      name: nb.parentName,
      item: `${site.url}/bolgeler/${nb.parent}/`,
    },
    { "@type": "ListItem", position: 4, name: nb.name, item: canonical },
  ],
};

const placePage = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${canonical}#place`,
  name: nb.fullName,
  description: nb.intro,
  url: canonical,
  image: `${site.url}${heroImage.split("?")[0]}`,
  geo: {
    "@type": "GeoCoordinates",
    latitude: nb.geo.lat,
    longitude: nb.geo.lng,
  },
  containedInPlace: {
    "@type": "AdministrativeArea",
    name: nb.parentName,
    containedInPlace: { "@type": "AdministrativeArea", name: "Muğla" },
  },
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonical}#service`,
  name: `${nb.name} gayrimenkul danışmanlığı`,
  description: nb.tldr,
  serviceType: "Gayrimenkul danışmanlığı",
  provider: { "@id": `${site.url}/#organization` },
  areaServed: {
    "@type": "Place",
    name: nb.name,
    geo: {
      "@type": "GeoCoordinates",
      latitude: nb.geo.lat,
      longitude: nb.geo.lng,
    },
  },
  category: nb.segments,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonical}#faq`,
  mainEntity: nb.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${site.url}${heroImage.split("?")[0]}`}
  jsonLd={[breadcrumb, placePage, serviceSchema, faqSchema]}
>
  <Header />
  <main id="main" class="nb-page">
    <section class="nb-hero">
      <img class="nb-hero-bg" src={heroImage} alt={`${nb.name}, ${nb.parentName} — Muğla`} loading="eager" decoding="async" />
      <div class="nb-hero-scrim" aria-hidden="true"></div>
      <div class="container nb-hero-inner">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <a href="/#bolgeler">Bölgeler</a>
          <span aria-hidden="true">/</span>
          <a href={`/bolgeler/${nb.parent}/`}>{nb.parentName}</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{nb.name}</span>
        </nav>
        <p class="eyebrow nb-hero-eyebrow">{nb.parentName} · Mahalle</p>
        <h1>{nb.fullName}</h1>
        <p class="nb-intro">{nb.intro}</p>
        <div class="nb-actions">
          <a href="/#iletisim" class="btn btn-primary">{nb.name} için danışmanlık alın</a>
          <a href={`/bolgeler/${nb.parent}/`} class="btn nb-hero-ghost">{nb.parentName} sayfasına dön</a>
        </div>
      </div>
    </section>

    <!-- TL;DR -->
    <section class="nb-tldr-section">
      <div class="container">
        <aside class="nb-tldr" aria-label={`${nb.name} özet`}>
          <p class="nb-tldr-label">Kısa Özet</p>
          <p class="nb-tldr-text"><strong>{nb.tldr}</strong></p>
        </aside>
      </div>
    </section>

    <!-- Detail + Segments -->
    <section class="section">
      <div class="container">
        <div class="nb-profile">
          <div class="nb-profile-main">
            <header class="section-head">
              <p class="eyebrow">Mahalle Profili</p>
              <h2>{nb.name} gayrimenkul piyasası</h2>
            </header>
            <p class="nb-detail">{nb.detail}</p>
          </div>
          <aside class="nb-aside">
            <p class="nb-aside-label">Hizmet verdiğimiz tipler</p>
            <div class="nb-segments">
              {nb.segments.map((s) => <span>{s}</span>)}
            </div>
            {siblingNeighborhoods.length > 0 && (
              <>
                <p class="nb-aside-label nb-aside-second">{nb.parentName} diğer mahalleler</p>
                <ul class="nb-sibling-list">
                  {siblingNeighborhoods.map((sn) => (
                    <li>
                      <a href={`/bolgeler/${sn.parent}/${sn.slug}/`}>
                        {sn.name} →
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section-alt">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Sıkça Sorulanlar</p>
          <h2>{nb.name}'de gayrimenkul — SSS</h2>
        </header>
        <div class="faq-list">
          {
            nb.faq.map((item, i) => (
              <details class="faq-item" open={i === 0}>
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </summary>
                <div class="faq-a">
                  <p>{item.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="nb-cta-section">
      <div class="container nb-cta">
        <p class="eyebrow">İletişim</p>
        <h2>{nb.name}'de gayrimenkul mü arıyorsunuz?</h2>
        <p>
          Çolakoğlu Emlak ekibi {nb.name} ve {nb.parentName} piyasasını yakından
          takip eder. Bütçenize ve beklentinize uygun seçenekler için bize ulaşın.
        </p>
        <a href="/#iletisim" class="btn btn-primary">İletişim formunu doldur</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .nb-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-h) + 3rem) 0 clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }

  .nb-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .nb-hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(20, 29, 57, 0.5) 0%,
      rgba(20, 29, 57, 0.18) 38%,
      rgba(16, 23, 46, 0.93) 100%
    );
  }

  .nb-hero-inner {
    position: relative;
    z-index: 2;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-bright);
    text-decoration: none;
  }

  .breadcrumb [aria-current="page"] {
    color: #fff;
  }

  .nb-hero-eyebrow {
    color: var(--color-gold-bright);
  }

  .nb-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.06;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 28px rgba(12, 18, 30, 0.4);
  }

  .nb-intro {
    max-width: 58ch;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.04rem;
    line-height: 1.65;
    margin: 0 0 1.75rem;
  }

  .nb-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .nb-hero-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(6px);
  }

  .nb-hero-ghost:hover {
    background: rgba(255, 255, 255, 0.16);
    border-color: #fff;
    color: #fff;
  }

  /* TL;DR */
  .nb-tldr-section {
    background: var(--color-paper-deep);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .nb-tldr {
    max-width: 820px;
    margin: 0 auto;
    padding: 1.5rem 1.85rem;
    background: var(--color-surface);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .nb-tldr-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin: 0 0 0.75rem;
  }

  .nb-tldr-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .nb-tldr-text strong {
    font-weight: 600;
  }

  /* Profile */
  .nb-profile {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: clamp(2rem, 4.5vw, 3.75rem);
    align-items: start;
  }

  @media (max-width: 820px) {
    .nb-profile {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }

  .nb-detail {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
    text-wrap: pretty;
    max-width: 62ch;
  }

  .nb-aside {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.85rem 1.9rem;
  }

  .nb-aside-label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 1.1rem;
  }

  .nb-aside-second {
    margin-top: 1.85rem;
  }

  .nb-segments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .nb-segments span {
    padding: 0.5rem 0.95rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    color: var(--color-ink);
  }

  .nb-sibling-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nb-sibling-list a {
    display: block;
    padding: 0.7rem 0.95rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: border-color 0.2s, transform 0.2s var(--ease-out);
  }

  .nb-sibling-list a:hover {
    border-color: var(--color-navy);
    transform: translateX(3px);
    text-decoration: none;
  }

  /* FAQ — region pattern */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 820px;
    margin-inline: auto;
  }

  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color 0.2s, box-shadow 0.25s;
  }

  .faq-item[open] {
    border-color: var(--color-navy);
    box-shadow: var(--shadow-card);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-size: 1.04rem;
    line-height: 1.4;
  }

  .faq-toggle {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    font-size: 1.2rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-gold);
    transition: transform 0.3s var(--ease-out), background 0.2s, color 0.2s;
  }

  .faq-item[open] .faq-toggle {
    transform: rotate(135deg);
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: #fff;
  }

  .faq-a {
    padding: 0 1.35rem 1.35rem;
  }

  .faq-a p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
  }

  /* CTA */
  .nb-cta-section {
    background: var(--color-wood-deep);
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  .nb-cta {
    text-align: center;
    max-width: 620px;
    margin-inline: auto;
  }

  .nb-cta .eyebrow {
    color: var(--color-gold-bright);
    justify-content: center;
  }

  .nb-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.2vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.12;
    margin: 0 0 1rem;
    color: #fff;
  }

  .nb-cta p {
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.66;
    margin: 0 0 1.75rem;
  }
</style>
