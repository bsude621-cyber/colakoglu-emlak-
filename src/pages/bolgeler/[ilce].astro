---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { regions, type Region } from "../../data/regions";
import { site } from "../../data/config";

export async function getStaticPaths() {
  return regions.map((r) => ({
    params: { ilce: r.slug },
    props: { region: r },
  }));
}

interface Props {
  region: Region;
}

const { region } = Astro.props;
const title = `${region.fullName} | ${site.name}`;
const description = region.intro.slice(0, 155);
const canonical = `${site.url}/bolgeler/${region.slug}/`;

const heroImage = `/images/ilce-${region.slug}.webp`;
const heroAltMap: Record<string, string> = {
  bodrum: "Bodrum Kalesi ve kıyı manzarası",
  marmaris: "Ege kıyısında yat koyu manzarası",
  fethiye: "Fethiye Ölüdeniz mavi lagün",
  milas: "Zeytinlik ve Ege kırsalı",
  datca: "Datça yarımadası koyu",
  koycegiz: "Köyceğiz Gölü",
  ortaca: "İztuzu sahili, Ortaca",
  dalaman: "Orman içinden akan nehir ve doğal çevre",
};
const heroImageAlt = heroAltMap[region.slug] ?? region.fullName;

const guides = [
  {
    href: "/rehber/muglada-yatirimlik-arazi/",
    title: "Muğla'da Yatırımlık Arazi Nasıl Seçilir?",
  },
  {
    href: "/rehber/tapu-devir-sureci/",
    title: "Tapu Devir İşlemleri Adım Adım",
  },
  {
    href: "/rehber/yabanciya-gayrimenkul-satisi/",
    title: "Yabancıya Gayrimenkul Satışı",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Bölgeler", item: `${site.url}/#bolgeler` },
    { "@type": "ListItem", position: 3, name: region.name, item: canonical },
  ],
};

const placePage = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${canonical}#place`,
  name: region.fullName,
  description: region.intro,
  url: canonical,
  image: `${site.url}${heroImage}`,
  geo: {
    "@type": "GeoCoordinates",
    latitude: region.geo.lat,
    longitude: region.geo.lng,
  },
  containedInPlace: { "@type": "AdministrativeArea", name: "Muğla" },
};

const realEstateService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonical}#service`,
  name: `${region.name} gayrimenkul danışmanlığı`,
  description: `${region.name}'de konut, arsa ve ticari gayrimenkul alım-satım, kiralama, değerleme ve yatırım danışmanlığı. ${region.intro}`,
  serviceType: "Gayrimenkul danışmanlığı",
  provider: { "@id": `${site.url}/#organization` },
  areaServed: {
    "@type": "City",
    name: region.name,
    geo: {
      "@type": "GeoCoordinates",
      latitude: region.geo.lat,
      longitude: region.geo.lng,
    },
  },
  category: region.segments,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonical}#faq`,
  mainEntity: region.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${site.url}${heroImage}`}
  jsonLd={[breadcrumb, placePage, realEstateService, faqSchema]}
>
  <Header />
  <main id="main" class="region-page">
    <section class="region-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">›</span>
          <a href="/#bolgeler">Bölgeler</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{region.name}</span>
        </nav>
        <p class="eyebrow">Muğla · Bölge sayfası</p>
        <h1>{region.fullName}</h1>
        <p class="region-intro">{region.intro}</p>
        <div class="region-actions">
          <a href="/#iletisim" class="btn btn-primary">{region.name} için danışmanlık alın</a>
          <a href="/#surec" class="btn btn-ghost">Nasıl çalışırız</a>
        </div>
      </div>
    </section>

    <div class="container">
      <figure class="region-figure">
        <img src={heroImage} alt={heroImageAlt} loading="eager" decoding="async" />
      </figure>
    </div>

    <section class="section section-alt">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Bölge profili</p>
          <h2>{region.name} gayrimenkul piyasası</h2>
        </header>
        <ul class="checklist region-highlights">
          {region.highlights.map((h) => <li>{h}</li>)}
        </ul>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Segmentler</p>
          <h2>{region.name}'de hizmet verdiğimiz gayrimenkul tipleri</h2>
        </header>
        <div class="region-segments">
          {region.segments.map((s) => <span>{s}</span>)}
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container region-faq">
        <header class="section-head">
          <p class="eyebrow">Sıkça sorulanlar</p>
          <h2>{region.name}'de gayrimenkul — SSS</h2>
        </header>
        <div class="faq-list">
          {
            region.faq.map((item) => (
              <details class="faq-item">
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </summary>
                <div class="faq-a">
                  <p>{item.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container region-guides">
        <header class="section-head">
          <p class="eyebrow">İlgili rehberler</p>
          <h2>Karar öncesi okumanızı öneririz</h2>
        </header>
        <div class="guide-links">
          {
            guides.map((g) => (
              <a href={g.href} class="guide-link">
                <span>{g.title}</span>
                <span class="guide-link-go" aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container region-cta">
        <h2>{region.name}'de gayrimenkul mü arıyorsunuz?</h2>
        <p>
          Çolakoğlu Emlak ekibi {region.name} piyasasını yakından takip eder.
          Bütçenize ve beklentinize uygun seçenekler için bize ulaşın.
        </p>
        <a href="/#iletisim" class="btn btn-primary">İletişim formunu doldur</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .region-page {
    padding-top: var(--header-h);
  }

  .region-hero {
    padding: calc(4rem + 1rem) 0 3rem;
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 2px solid var(--color-gold);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .breadcrumb [aria-current="page"] {
    color: var(--color-ink);
  }

  .region-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .region-intro {
    max-width: 56ch;
    color: var(--color-ink-muted);
    font-size: 1.05rem;
    line-height: 1.62;
    margin: 0 0 1.5rem;
  }

  .region-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .region-figure {
    margin: 0;
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .region-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .region-highlights {
    max-width: 60ch;
    font-size: 1rem;
  }

  .region-segments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .region-segments span {
    padding: 0.55rem 1.1rem;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    border: 1px solid var(--color-line);
    color: var(--color-ink);
  }

  /* Bölge SSS */
  .faq-list {
    display: grid;
    gap: 0.75rem;
    max-width: 820px;
  }

  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
  }

  .faq-item[open] {
    border-color: var(--color-navy);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 1.25rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-weight: 600;
    color: var(--color-ink);
    font-size: 1rem;
  }

  .faq-toggle {
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--color-gold);
    flex-shrink: 0;
    transition: transform 0.25s var(--ease-out);
  }

  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
  }

  .faq-a {
    padding: 0 1.25rem 1.25rem;
  }

  .faq-a p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
  }

  /* İlgili rehberler */
  .guide-links {
    display: grid;
    gap: 0.75rem;
    max-width: 820px;
  }

  .guide-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.35rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 600;
    transition: transform 0.2s var(--ease-out), border-color 0.2s;
  }

  .guide-link:hover {
    transform: translateY(-2px);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .guide-link-go {
    color: var(--color-gold);
    font-weight: 700;
    flex-shrink: 0;
  }

  .region-cta {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .region-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .region-cta p {
    color: var(--color-ink-muted);
    margin: 0 0 1.5rem;
  }
</style>
