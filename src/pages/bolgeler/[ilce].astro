---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { regions, type Region } from "../../data/regions";
import { site } from "../../data/config";

export async function getStaticPaths() {
  return regions.map((r) => ({
    params: { ilce: r.slug },
    props: { region: r },
  }));
}

interface Props {
  region: Region;
}

const { region } = Astro.props;
const title = `${region.fullName} | ${site.name}`;
const description = region.intro.slice(0, 155);
const canonical = `${site.url}/bolgeler/${region.slug}/`;

const heroImage = `/images/ilce-${region.slug}.webp`;
const heroAltMap: Record<string, string> = {
  bodrum: "Bodrum Kalesi ve kıyı manzarası",
  marmaris: "Ege kıyısında yat koyu manzarası",
  fethiye: "Fethiye Ölüdeniz mavi lagün",
  milas: "Zeytinlik ve Ege kırsalı",
  datca: "Datça yarımadası koyu",
  koycegiz: "Köyceğiz Gölü",
  ortaca: "İztuzu sahili, Ortaca",
  dalaman: "Orman içinden akan nehir ve doğal çevre",
  mentese: "Muğla şehir merkezi ve tarihi dokusu",
  ula: "Akyaka — Gökova körfezi, sazlıklar ve çam ormanı",
  yatagan: "Stratonikeia antik kenti, Yatağan",
  kavaklidere: "Kavaklıdere — Göktepe'den yayla manzarası",
  seydikemer: "Saklıkent Kanyonu, Seydikemer",
};
const heroImageAlt = heroAltMap[region.slug] ?? region.fullName;

const guides = [
  {
    href: "/rehber/muglada-yatirimlik-arazi/",
    title: "Muğla'da Yatırımlık Arazi Nasıl Seçilir?",
  },
  {
    href: "/rehber/tapu-devir-sureci/",
    title: "Tapu Devir İşlemleri Adım Adım",
  },
  {
    href: "/rehber/yabanciya-gayrimenkul-satisi/",
    title: "Yabancıya Gayrimenkul Satışı",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Bölgeler", item: `${site.url}/#bolgeler` },
    { "@type": "ListItem", position: 3, name: region.name, item: canonical },
  ],
};

const placePage = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${canonical}#place`,
  name: region.fullName,
  description: region.intro,
  url: canonical,
  image: `${site.url}${heroImage}`,
  geo: {
    "@type": "GeoCoordinates",
    latitude: region.geo.lat,
    longitude: region.geo.lng,
  },
  containedInPlace: { "@type": "AdministrativeArea", name: "Muğla" },
};

const realEstateService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonical}#service`,
  name: `${region.name} gayrimenkul danışmanlığı`,
  description: `${region.name}'de konut, arsa ve ticari gayrimenkul alım-satım, kiralama, değerleme ve yatırım danışmanlığı. ${region.intro}`,
  serviceType: "Gayrimenkul danışmanlığı",
  provider: { "@id": `${site.url}/#organization` },
  areaServed: {
    "@type": "City",
    name: region.name,
    geo: {
      "@type": "GeoCoordinates",
      latitude: region.geo.lat,
      longitude: region.geo.lng,
    },
  },
  category: region.segments,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonical}#faq`,
  mainEntity: region.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${site.url}${heroImage}`}
  jsonLd={[breadcrumb, placePage, realEstateService, faqSchema]}
>
  <Header />
  <main id="main" class="region-page">
    <!-- Tam kadraj bölge görseli hero -->
    <section class="region-hero">
      <img
        class="region-hero-bg"
        src={heroImage}
        alt={heroImageAlt}
        loading="eager"
        decoding="async"
      />
      <div class="region-hero-scrim" aria-hidden="true"></div>
      <div class="container region-hero-inner">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <a href="/#bolgeler">Bölgeler</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{region.name}</span>
        </nav>
        <p class="eyebrow region-hero-eyebrow">Muğla · Bölge Rehberi</p>
        <h1>{region.fullName}</h1>
        <p class="region-intro">{region.intro}</p>
        <div class="region-actions">
          <a href="/#iletisim" class="btn btn-primary">
            {region.name} için danışmanlık alın
          </a>
          <a href="/#surec" class="btn region-hero-ghost">Nasıl çalışırız</a>
        </div>
      </div>
    </section>

    <!-- TL;DR — AI Overview citation pattern (50-80 word, izole anlamlı, citation-friendly) -->
    <section class="region-tldr-section">
      <div class="container">
        <aside class="region-tldr" aria-label={`${region.name} özet`}>
          <p class="region-tldr-label">Kısa Özet</p>
          <p class="region-tldr-text"><strong>{region.tldr}</strong></p>
        </aside>
      </div>
    </section>

    <!-- Bölge profili + gayrimenkul tipleri -->
    <section class="section">
      <div class="container">
        <div class="region-profile">
          <div class="region-profile-main">
            <header class="section-head">
              <p class="eyebrow">Bölge Profili</p>
              <h2>{region.name} gayrimenkul piyasası</h2>
            </header>
            <p class="region-detail">{region.detail}</p>
            <ul class="region-highlights">
              {
                region.highlights.map((h) => (
                  <li>
                    <svg
                      viewBox="0 0 24 24"
                      width="18"
                      height="18"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4.5 12.6 9.5 17.5 19.5 6.5" />
                    </svg>
                    <span>{h}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <aside class="region-types">
            <p class="region-types-label">Hizmet verdiğimiz tipler</p>
            <div class="region-segments">
              {region.segments.map((s) => <span>{s}</span>)}
            </div>
            <a href="/#iletisim" class="region-types-cta">
              Portföy için bize ulaşın
              <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                <path
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 12h14M13 6l6 6-6 6"
                ></path>
              </svg>
            </a>
          </aside>
        </div>
      </div>
    </section>

    <!-- Bölge SSS -->
    <section class="section section-alt">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Sıkça Sorulanlar</p>
          <h2>{region.name}'de gayrimenkul — SSS</h2>
        </header>
        <div class="faq-list">
          {
            region.faq.map((item, i) => (
              <details class="faq-item" open={i === 0}>
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </summary>
                <div class="faq-a">
                  <p>{item.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- İlgili rehberler -->
    <section class="section">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">İlgili Rehberler</p>
          <h2>Karar öncesi okumanızı öneririz</h2>
        </header>
        <div class="guide-links">
          {
            guides.map((g) => (
              <a href={g.href} class="guide-link">
                <span>{g.title}</span>
                <span class="guide-link-go" aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Koyu kapanış CTA -->
    <section class="region-cta-section">
      <div class="container region-cta">
        <p class="eyebrow">İletişim</p>
        <h2>{region.name}'de gayrimenkul mü arıyorsunuz?</h2>
        <p>
          Çolakoğlu Emlak ekibi {region.name} piyasasını yakından takip eder.
          Bütçenize ve beklentinize uygun seçenekler için bize ulaşın.
        </p>
        <a href="/#iletisim" class="btn btn-primary">İletişim formunu doldur</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ---- Tam kadraj hero ---- */
  .region-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-h) + 3rem) 0 clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }

  .region-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .region-hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(20, 29, 57, 0.5) 0%,
      rgba(20, 29, 57, 0.18) 38%,
      rgba(16, 23, 46, 0.93) 100%
    );
  }

  .region-hero-inner {
    position: relative;
    z-index: 2;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-bright);
    text-decoration: none;
  }

  .breadcrumb [aria-current="page"] {
    color: #fff;
  }

  .region-hero-eyebrow {
    color: var(--color-gold-bright);
  }

  .region-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 28px rgba(12, 18, 30, 0.4);
  }

  .region-intro {
    max-width: 56ch;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.06rem;
    line-height: 1.65;
    margin: 0 0 1.75rem;
  }

  .region-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .region-hero-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(6px);
  }

  .region-hero-ghost:hover {
    background: rgba(255, 255, 255, 0.16);
    border-color: #fff;
    color: #fff;
  }

  /* ---- TL;DR — AI Overview citation pattern ---- */
  .region-tldr-section {
    background: var(--color-paper-deep);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .region-tldr {
    max-width: 820px;
    margin: 0 auto;
    padding: 1.5rem 1.85rem;
    background: var(--color-surface);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .region-tldr-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin: 0 0 0.75rem;
  }

  .region-tldr-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .region-tldr-text strong {
    font-weight: 600;
  }

  /* Detail metni — yerel piyasa karakteri */
  .region-detail {
    margin: 0 0 1.75rem;
    font-size: 1.02rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
    text-wrap: pretty;
    max-width: 62ch;
  }

  /* ---- Bölge profili ---- */
  .region-profile {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: clamp(2rem, 4.5vw, 3.75rem);
    align-items: start;
  }

  @media (max-width: 820px) {
    .region-profile {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }

  .region-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
  }

  .region-highlights li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1.03rem;
    line-height: 1.55;
    color: var(--color-ink);
    padding-bottom: 0.95rem;
    border-bottom: 1px solid var(--color-line);
  }

  .region-highlights li:last-child {
    border-bottom: none;
  }

  .region-highlights svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-gold);
  }

  /* Tipler paneli */
  .region-types {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.85rem 1.9rem;
  }

  .region-types-label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 1.1rem;
  }

  .region-segments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .region-segments span {
    padding: 0.5rem 0.95rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    color: var(--color-ink);
  }

  .region-types-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    text-decoration: none;
  }

  .region-types-cta:hover {
    text-decoration: none;
  }

  .region-types-cta svg {
    transition: transform 0.2s var(--ease-out);
  }

  .region-types-cta:hover svg {
    transform: translateX(3px);
  }

  /* ---- Bölge SSS ---- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 820px;
    margin-inline: auto;
  }

  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color 0.2s, box-shadow 0.25s;
  }

  .faq-item[open] {
    border-color: var(--color-navy);
    box-shadow: var(--shadow-card);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-size: 1.04rem;
    line-height: 1.4;
  }

  .faq-toggle {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    font-size: 1.2rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-gold);
    transition: transform 0.3s var(--ease-out), background 0.2s, color 0.2s;
  }

  .faq-item[open] .faq-toggle {
    transform: rotate(135deg);
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: #fff;
  }

  .faq-a {
    padding: 0 1.35rem 1.35rem;
  }

  .faq-a p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
  }

  /* ---- İlgili rehberler ---- */
  .guide-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 760px) {
    .guide-links {
      grid-template-columns: 1fr;
    }
  }

  .guide-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.3rem 1.4rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 600;
    font-size: 0.97rem;
    line-height: 1.4;
    transition: transform 0.2s var(--ease-out), border-color 0.2s, box-shadow 0.25s;
  }

  .guide-link:hover {
    transform: translateY(-4px);
    border-color: var(--color-navy);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
  }

  .guide-link-go {
    color: var(--color-gold);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ---- Koyu kapanış CTA ---- */
  .region-cta-section {
    background: var(--color-wood-deep);
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  .region-cta {
    text-align: center;
    max-width: 620px;
    margin-inline: auto;
  }

  .region-cta .eyebrow {
    color: var(--color-gold-bright);
    justify-content: center;
  }

  .region-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.2vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.12;
    margin: 0 0 1rem;
    color: #fff;
  }

  .region-cta p {
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.66;
    margin: 0 0 1.75rem;
  }
</style>
