---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { services, site, type Service } from "../../data/config";

export async function getStaticPaths() {
  return services.map((s) => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const title = `${service.name} | ${site.name}`;
const description = service.tldr.slice(0, 155);
const canonical = `${site.url}/hizmetler/${service.slug}/`;

const otherServices = services.filter((s) => s.slug !== service.slug);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Hizmetler", item: `${site.url}/#hizmetler` },
    { "@type": "ListItem", position: 3, name: service.name, item: canonical },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${canonical}#service`,
  name: service.name,
  description: service.tldr,
  serviceType: service.name,
  provider: { "@id": `${site.url}/#organization` },
  areaServed: {
    "@type": "AdministrativeArea",
    name: site.region,
    containedInPlace: { "@type": "Country", name: "Türkiye" },
  },
  url: canonical,
  mainEntityOfPage: canonical,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonical}#faq`,
  mainEntity: service.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, serviceSchema, faqSchema]}
>
  <Header />
  <main id="main" class="service-page">
    <header class="service-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <a href="/#hizmetler">Hizmetler</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{service.name}</span>
        </nav>
        <p class="eyebrow">Hizmet</p>
        <h1>{service.name}</h1>
        <p class="service-description">{service.description}</p>
        <div class="service-actions">
          <a href="/#iletisim" class="btn btn-primary">Danışmanlık alın</a>
          <a href="tel:+902522125015" class="btn service-hero-ghost">0252 212 50 15</a>
        </div>
      </div>
    </header>

    <!-- TL;DR — AI Overview citation pattern -->
    <section class="service-tldr-section">
      <div class="container">
        <aside class="service-tldr" aria-label={`${service.name} özet`}>
          <p class="service-tldr-label">Kısa Özet</p>
          <p class="service-tldr-text"><strong>{service.tldr}</strong></p>
        </aside>
      </div>
    </section>

    <!-- Detail + Highlights -->
    <section class="section">
      <div class="container">
        <div class="service-profile">
          <div class="service-profile-main">
            <header class="section-head">
              <p class="eyebrow">Hizmet Detayı</p>
              <h2>Süreç ve kapsam</h2>
            </header>
            <p class="service-detail">{service.detail}</p>
            <ul class="service-highlights">
              {
                service.highlights.map((h) => (
                  <li>
                    <svg
                      viewBox="0 0 24 24"
                      width="18"
                      height="18"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M4.5 12.6 9.5 17.5 19.5 6.5" />
                    </svg>
                    <span>{h}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <aside class="service-aside">
            <p class="service-aside-label">Diğer hizmetlerimiz</p>
            <ul class="service-aside-list">
              {
                otherServices.map((s) => (
                  <li>
                    <a href={`/hizmetler/${s.slug}/`}>
                      <span class="service-aside-icon" aria-hidden="true">
                        {s.icon}
                      </span>
                      <span>{s.name}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section-alt">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Sıkça Sorulanlar</p>
          <h2>{service.name} — SSS</h2>
        </header>
        <div class="faq-list">
          {
            service.faq.map((item, i) => (
              <details class="faq-item" open={i === 0}>
                <summary>
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </summary>
                <div class="faq-a">
                  <p>{item.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="service-cta-section">
      <div class="container service-cta">
        <p class="eyebrow">İletişim</p>
        <h2>{service.name} hakkında konuşalım</h2>
        <p>
          Çolakoğlu Emlak ekibi {service.name.toLowerCase()} süreçlerinizi
          baştan sona koordineli yürütür. Bütçeniz ve hedefiniz için bize
          ulaşın.
        </p>
        <a href="/#iletisim" class="btn btn-primary">Danışmanlık alın</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .service-page {
    padding-top: var(--header-h);
  }

  .service-hero {
    padding: calc(var(--header-h) + 2.5rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    background: var(--color-wood-deep);
  }

  .service-hero .eyebrow {
    color: var(--color-gold-bright);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-bright);
    text-decoration: none;
  }

  .breadcrumb [aria-current="page"] {
    color: #fff;
  }

  .service-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    color: #fff;
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .service-description {
    max-width: 56ch;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.06rem;
    line-height: 1.65;
    margin: 0 0 1.75rem;
  }

  .service-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .service-hero-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.42);
    backdrop-filter: blur(6px);
  }

  .service-hero-ghost:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: #fff;
    color: #fff;
  }

  /* TL;DR */
  .service-tldr-section {
    background: var(--color-paper-deep);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .service-tldr {
    max-width: 820px;
    margin: 0 auto;
    padding: 1.5rem 1.85rem;
    background: var(--color-surface);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .service-tldr-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin: 0 0 0.75rem;
  }

  .service-tldr-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .service-tldr-text strong {
    font-weight: 600;
  }

  /* Profile (detail + highlights + aside) */
  .service-profile {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: clamp(2rem, 4.5vw, 3.75rem);
    align-items: start;
  }

  @media (max-width: 820px) {
    .service-profile {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }

  .service-detail {
    margin: 0 0 1.85rem;
    font-size: 1.02rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
    text-wrap: pretty;
    max-width: 62ch;
  }

  .service-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
  }

  .service-highlights li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-ink);
    padding-bottom: 0.95rem;
    border-bottom: 1px solid var(--color-line);
  }

  .service-highlights li:last-child {
    border-bottom: none;
  }

  .service-highlights svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-gold);
  }

  /* Aside — diğer hizmetler */
  .service-aside {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.85rem 1.9rem;
  }

  .service-aside-label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 1.1rem;
  }

  .service-aside-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .service-aside-list a {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 0.95rem;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: border-color 0.2s, transform 0.2s var(--ease-out);
  }

  .service-aside-list a:hover {
    border-color: var(--color-navy);
    transform: translateX(3px);
    text-decoration: none;
  }

  .service-aside-icon {
    color: var(--color-gold);
    font-size: 1.1rem;
  }

  /* FAQ — region pattern */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 820px;
    margin-inline: auto;
  }

  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color 0.2s, box-shadow 0.25s;
  }

  .faq-item[open] {
    border-color: var(--color-navy);
    box-shadow: var(--shadow-card);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    font-size: 1.04rem;
    line-height: 1.4;
  }

  .faq-toggle {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    font-size: 1.2rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-gold);
    transition: transform 0.3s var(--ease-out), background 0.2s, color 0.2s;
  }

  .faq-item[open] .faq-toggle {
    transform: rotate(135deg);
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: #fff;
  }

  .faq-a {
    padding: 0 1.35rem 1.35rem;
  }

  .faq-a p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.72;
    color: var(--color-ink-muted);
  }

  /* CTA */
  .service-cta-section {
    background: var(--color-wood-deep);
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  .service-cta {
    text-align: center;
    max-width: 620px;
    margin-inline: auto;
  }

  .service-cta .eyebrow {
    color: var(--color-gold-bright);
    justify-content: center;
  }

  .service-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.2vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.12;
    margin: 0 0 1rem;
    color: #fff;
  }

  .service-cta p {
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.66;
    margin: 0 0 1.75rem;
  }
</style>
