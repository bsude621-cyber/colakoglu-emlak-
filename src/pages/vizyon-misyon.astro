---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/config";

const title = `Vizyon & Misyon | ${site.name}`;
const description =
  "Çolakoğlu Emlak'ın vizyonu, misyonu ve çalışma değerleri — 25 yıllık tecrübe, mesleki etik ve güvene dayalı gayrimenkul danışmanlığı anlayışı. Muğla.";
const canonical = `${site.url}/vizyon-misyon/`;

const values = [
  {
    title: "Güven ve şeffaflık",
    text: "\"Emlakçılıkta Güven Esastır\" ilkesi her sürecin merkezinde. Gizli bilgi, sürpriz maliyet yok — her aşamada açık iletişim.",
  },
  {
    title: "Mesleki etik",
    text: "Meslek odası başkanlığının getirdiği sorumluluk. Sektörel etik standartları savunmak ve uygulamada örnek olmak.",
  },
  {
    title: "Yerel uzmanlık",
    text: "Muğla'nın sekiz ilçesini ayrı ayrı, mahalle ölçeğinde tanımak. Her bölgeye özel, gerçek piyasa verisine dayalı strateji.",
  },
  {
    title: "Hukuki titizlik",
    text: "Tapu, imar ve sözleşme süreçlerinde güvenilir hukuk ve mali müşavir iş ortaklarıyla koordineli, kayıtlı ilerleme.",
  },
  {
    title: "Uzun vadeli ilişki",
    text: "Tek bir işlem değil; teslim sonrasında da süren, danışan ile danışman arasında kalıcı bir güven bağı.",
  },
  {
    title: "Erişilebilirlik",
    text: "Yabancı yatırımcılara dil ve hukuk desteği. Herkes için anlaşılır, adım adım izlenebilir bir süreç.",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Vizyon & Misyon", item: canonical },
  ],
};

const aboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${canonical}#webpage`,
  name: `Vizyon & Misyon — ${site.name}`,
  description,
  url: canonical,
  inLanguage: "tr-TR",
  isPartOf: { "@id": `${site.url}/#website` },
  about: { "@id": `${site.url}/#organization` },
  breadcrumb: { "@id": `${canonical}#breadcrumb` },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, aboutPage]}
>
  <Header />
  <main id="main" class="vm-page">
    <section class="vm-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">Vizyon &amp; Misyon</span>
        </nav>
        <p class="eyebrow">{site.name} · Kurumsal</p>
        <h1>Vizyonumuz ve Misyonumuz</h1>
        <p class="vm-lead">
          Çolakoğlu Emlak'ı sıradan bir emlak ofisinden ayıran şey, 25 yıllık
          tecrübenin ötesinde bir duruştur: güvene, mesleki etiğe ve uzun
          vadeli ilişkiye dayalı bir danışmanlık anlayışı.
        </p>
      </div>
    </section>

    <div class="container">
      <figure class="vm-figure">
        <img
          src="/images/ilce-datca.webp"
          alt="Muğla Ege kıyısı — Çolakoğlu Emlak'ın hizmet bölgesi"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>

    <section class="section">
      <div class="container vm-statement">
        <p class="eyebrow">Vizyon</p>
        <p class="vm-big">
          Muğla'da gayrimenkul danışmanlığını <strong>güvenin ve mesleki
          etiğin standardı</strong> hâline getirmek; her ailenin ve her
          yatırımcının doğru kararı eksiksiz bilgiyle, huzurla alabildiği bir
          sektör.
        </p>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container vm-statement">
        <p class="eyebrow">Misyon</p>
        <p class="vm-big">
          25 yıllık saha tecrübesi ve sektörün meslek odası temsilciliğiyle;
          alım, satım, kiralama, değerleme ve yatırım süreçlerinin her
          aşamasında <strong>şeffaf, hukuki açıdan titiz ve baştan sona
          eşlikli</strong> bir danışmanlık sunmak — danışanın çıkarını her
          zaman önce tutarak.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Neye göre çalışırız</p>
          <h2>Değerlerimiz</h2>
          <p class="section-desc">
            Her görüşmede, her sözleşmede ve her teslimde bizi yönlendiren
            altı ilke.
          </p>
        </header>
        <div class="grid cards vm-values">
          {
            values.map((v) => (
              <article class="card">
                <h3>{v.title}</h3>
                <p>{v.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="vm-cta">
      <div class="container">
        <p class="eyebrow">Güvene dayalı danışmanlık</p>
        <h2>Doğru kararı birlikte verelim</h2>
        <p>
          Alım, satım, kiralama veya değerleme — sürecinizi Muğla'nın meslek
          odası temsilcisiyle, baştan sona eşlikli yürütün.
        </p>
        <a href="/#iletisim" class="vm-cta-btn">Danışmanlık alın</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .vm-page {
    padding-top: var(--header-h);
  }

  .vm-hero {
    padding: calc(4rem + 1rem) 0 3rem;
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 2px solid var(--color-gold);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--color-ink);
  }

  .vm-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .vm-lead {
    max-width: 58ch;
    color: var(--color-ink-muted);
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0;
  }

  .vm-figure {
    margin: 0;
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .vm-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vm-statement {
    max-width: 820px;
  }

  .vm-big {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.4vw, 2.55rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
    text-wrap: balance;
  }

  .vm-big strong {
    font-weight: 600;
    color: var(--color-gold-deep);
  }

  .vm-values {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .vm-values {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .vm-values {
      grid-template-columns: 1fr;
    }
  }

  .vm-cta {
    background: var(--color-navy-deep, #1e2a34);
    color: #fff;
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
    text-align: center;
  }

  .vm-cta .eyebrow {
    justify-content: center;
    color: var(--color-gold-bright);
  }

  .vm-cta .eyebrow::before {
    background: var(--color-gold-bright);
  }

  .vm-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.4vw, 2.65rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.85rem;
    color: #fff;
  }

  .vm-cta p {
    max-width: 48ch;
    margin: 0 auto 2rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.04rem;
    line-height: 1.6;
  }

  .vm-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 2rem;
    background: #fff;
    color: var(--color-navy-deep, #1e2a34);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: transform 0.16s var(--ease-out), background 0.2s;
  }

  .vm-cta-btn:hover {
    background: var(--color-gold-bright);
    text-decoration: none;
  }

  .vm-cta-btn:active {
    transform: scale(0.98);
  }
</style>
