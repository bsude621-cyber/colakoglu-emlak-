---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/config";

const title = `Vizyon ve Misyon | ${site.name}`;
const description =
  "Çolakoğlu Emlak'ın vizyonu, misyonu ve çalışma değerleri — 32 yıllık tecrübe, mesleki etik ve güvene dayalı gayrimenkul danışmanlığı anlayışı. Muğla.";
const canonical = `${site.url}/vizyon-misyon/`;

const values = [
  {
    title: "Güven ve şeffaflık",
    text: "\"Emlakçılıkta Güven Esastır\" ilkesi her sürecin merkezinde. Gizli bilgi, sürpriz maliyet yok — her aşamada açık iletişim.",
  },
  {
    title: "Mesleki etik",
    text: "Meslek odası başkanlığının getirdiği sorumluluk. Sektörel etik standartları savunmak ve uygulamada örnek olmak.",
  },
  {
    title: "Yerel uzmanlık",
    text: "Muğla'nın on üç ilçesini ayrı ayrı, mahalle ölçeğinde tanımak. Her bölgeye özel, gerçek piyasa verisine dayalı strateji.",
  },
  {
    title: "Hukuki titizlik",
    text: "Tapu, imar ve sözleşme süreçlerinde hukuk ve mali müşavir uzmanlarıyla koordineli, kayıtlı ilerleme.",
  },
  {
    title: "Uzun vadeli ilişki",
    text: "Tek bir işlem değil; teslim sonrasında da süren, danışan ile danışman arasında kalıcı bir güven bağı.",
  },
  {
    title: "Erişilebilirlik",
    text: "Her detay önceden netleşir, sürpriz maliyet yok. Adım adım izlenebilir bir süreç — danışan istediği anda nerede olduğunu bilir.",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Vizyon ve Misyon", item: canonical },
  ],
};

const aboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${canonical}#webpage`,
  name: `Vizyon ve Misyon — ${site.name}`,
  description,
  url: canonical,
  inLanguage: "tr-TR",
  isPartOf: { "@id": `${site.url}/#website` },
  about: { "@id": `${site.url}/#organization` },
  breadcrumb: { "@id": `${canonical}#breadcrumb` },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, aboutPage]}
>
  <Header />
  <main id="main" class="vm-page">
    <section class="vm-hero">
      <img
        class="vm-hero-bg"
        src="/images/ilce-datca.webp"
        alt="Muğla Ege kıyısı — Çolakoğlu Emlak'ın hizmet bölgesi"
        loading="eager"
        decoding="async"
      />
      <div class="vm-hero-scrim" aria-hidden="true"></div>
      <div class="container vm-hero-inner">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Vizyon ve Misyon</span>
        </nav>
        <p class="eyebrow vm-hero-eyebrow">{site.name} · Kurumsal</p>
        <h1>Vizyonumuz ve Misyonumuz</h1>
        <p class="vm-lead">
          Çolakoğlu Emlak'ı sıradan bir emlak ofisinden ayıran şey, 32 yıllık
          tecrübenin ötesinde bir duruştur: güvene, mesleki etiğe ve uzun
          vadeli ilişkiye dayalı bir danışmanlık anlayışı.
        </p>
      </div>
    </section>

    <!-- TL;DR — AI Overview citation pattern -->
    <section class="vm-tldr-section">
      <div class="container">
        <aside class="vm-tldr" aria-label="Vizyon ve misyon özet">
          <p class="vm-tldr-label">Kısa Özet</p>
          <p class="vm-tldr-text">
            <strong>
              Çolakoğlu Emlak'ın vizyonu, Muğla'da gayrimenkul danışmanlığını
              güvenin ve mesleki etiğin standardı hâline getirmektir. Misyonu;
              32 yıllık saha tecrübesi ve sektörün meslek odası temsilciliğiyle,
              alım-satım-kiralama-değerleme süreçlerinin her aşamasında şeffaf,
              hukuki açıdan titiz ve baştan sona eşlikli danışmanlık sunmaktır.
            </strong>
          </p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container vm-statement">
        <p class="eyebrow">Vizyon</p>
        <p class="vm-big">
          Muğla'da gayrimenkul danışmanlığını <strong>güvenin ve mesleki
          etiğin standardı</strong> hâline getirmek; her ailenin ve her
          yatırımcının doğru kararı eksiksiz bilgiyle, huzurla alabildiği bir
          sektör.
        </p>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container vm-statement">
        <p class="eyebrow">Misyon</p>
        <p class="vm-big">
          32 yıllık saha tecrübesi ve sektörün meslek odası temsilciliğiyle;
          alım, satım, kiralama, değerleme ve yatırım süreçlerinin her
          aşamasında <strong>şeffaf, hukuki açıdan titiz ve baştan sona
          eşlikli</strong> bir danışmanlık sunmak — danışanın çıkarını her
          zaman önce tutarak.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Neye göre çalışırız</p>
          <h2>Değerlerimiz</h2>
          <p class="section-desc">
            Her görüşmede, her sözleşmede ve her teslimde bizi yönlendiren
            altı ilke.
          </p>
        </header>
        <div class="grid cards vm-values">
          {
            values.map((v) => (
              <article class="card">
                <h3>{v.title}</h3>
                <p>{v.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="vm-cta">
      <div class="container">
        <p class="eyebrow">Güvene dayalı danışmanlık</p>
        <h2>Doğru kararı birlikte verelim</h2>
        <p>
          Alım, satım, kiralama veya değerleme — sürecinizi Muğla'nın meslek
          odası temsilcisiyle, baştan sona eşlikli yürütün.
        </p>
        <a href="/#iletisim" class="vm-cta-btn">Danışmanlık alın</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .vm-page {
    padding-top: var(--header-h);
  }

  .vm-hero {
    position: relative;
    min-height: 58vh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--header-h) + 3rem) 0 clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }

  .vm-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .vm-hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(20, 29, 57, 0.5) 0%,
      rgba(20, 29, 57, 0.18) 38%,
      rgba(16, 23, 46, 0.93) 100%
    );
  }

  .vm-hero-inner {
    position: relative;
    z-index: 2;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-bright);
  }

  .breadcrumb [aria-current="page"] {
    color: #fff;
  }

  .vm-hero-eyebrow {
    color: var(--color-gold-bright);
  }

  .vm-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 28px rgba(12, 18, 30, 0.4);
  }

  .vm-lead {
    max-width: 58ch;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0;
  }

  /* TL;DR — AI Overview citation pattern */
  .vm-tldr-section {
    background: var(--color-paper-deep);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .vm-tldr {
    max-width: 820px;
    margin: 0 auto;
    padding: 1.5rem 1.85rem;
    background: var(--color-surface);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .vm-tldr-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin: 0 0 0.75rem;
  }

  .vm-tldr-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.55;
    color: var(--color-ink);
  }

  .vm-tldr-text strong {
    font-weight: 600;
  }

  .vm-statement {
    max-width: 820px;
  }

  .vm-big {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.4vw, 2.55rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
    text-wrap: balance;
  }

  .vm-big strong {
    font-weight: 600;
    color: var(--color-gold-deep);
  }

  .vm-values {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .vm-values {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .vm-values {
      grid-template-columns: 1fr;
    }
  }

  .vm-cta {
    background: var(--color-navy-deep, #1e2a34);
    color: #fff;
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
    text-align: center;
  }

  .vm-cta .eyebrow {
    justify-content: center;
    color: var(--color-gold-bright);
  }

  .vm-cta .eyebrow::before {
    background: var(--color-gold-bright);
  }

  .vm-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.4vw, 2.65rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.85rem;
    color: #fff;
  }

  .vm-cta p {
    max-width: 48ch;
    margin: 0 auto 2rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.04rem;
    line-height: 1.6;
  }

  .vm-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 2rem;
    background: #fff;
    color: var(--color-navy-deep, #1e2a34);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: transform 0.16s var(--ease-out), background 0.2s;
  }

  .vm-cta-btn:hover {
    background: var(--color-gold-bright);
    text-decoration: none;
  }

  .vm-cta-btn:active {
    transform: scale(0.98);
  }
</style>
