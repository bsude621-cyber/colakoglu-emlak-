---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { site } from "../../data/config";
import { listings, statusLabel } from "../../data/listings";

const title = `Satılık & Kiralık İlanlar | ${site.name}`;
const description =
  "Çolakoğlu Emlak güncel portföyü — Muğla'nın 13 ilçesinde satılık ve kiralık konut, villa, arsa ve ticari gayrimenkul ilanları.";
const canonical = `${site.url}/ilanlar/`;

const featured = listings.filter((l) => l.featured);
const ordered = [...featured, ...listings.filter((l) => !l.featured)];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "İlanlar", item: canonical },
  ],
};

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${canonical}#listings`,
  name: "Çolakoğlu Emlak portföyü",
  numberOfItems: ordered.length,
  itemListElement: ordered.map((l, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${site.url}/ilanlar/${l.slug}/`,
    name: l.title,
  })),
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, itemList]}
>
  <Header />
  <main id="main" class="listings-page">
    <section class="listings-head-section">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">İlanlar</span>
        </nav>
        <p class="eyebrow">Portföy</p>
        <h1>Satılık &amp; kiralık ilanlar</h1>
        <p class="listings-lead">
          Muğla'nın 13 ilçesinde, Çolakoğlu Emlak güvencesiyle sunulan güncel
          portföy. Beğendiğiniz ilan için bizi arayın; bütçenize ve beklentinize
          uygun seçenekleri birlikte değerlendirelim.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {
          ordered.length > 0 ? (
            <div class="listing-grid">
              {ordered.map((l) => (
                <a href={`/ilanlar/${l.slug}/`} class="listing-card">
                  <div class="listing-card-media">
                    <img
                      src={l.images[0]}
                      alt={l.coverAlt}
                      loading="lazy"
                      decoding="async"
                    />
                    <span class={`listing-badge listing-badge--${l.status}`}>
                      {statusLabel(l.status)}
                    </span>
                  </div>
                  <div class="listing-card-body">
                    <p class="listing-card-loc">
                      {l.categoryLabel}
                      {l.mahalle ? ` · ${l.mahalle}, ${l.ilce}` : ` · ${l.ilce}`}
                    </p>
                    <h2 class="listing-card-title">{l.title}</h2>
                    <p class="listing-card-summary">{l.summary}</p>
                    <span class="listing-card-go">
                      Detayları gör
                      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
                        <path
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.9"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 12h14M13 6l6 6-6 6"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="listings-empty">
              <p class="listings-empty-label">Portföy hazırlanıyor</p>
              <h2>Güncel ilanlarımız çok yakında burada</h2>
              <p>
                Aradığınız konut, villa, arsa veya ticari gayrimenkul için
                beklemeden bize ulaşabilirsiniz. Portföyümüzdeki güncel
                seçenekleri sizinle telefonda paylaşalım.
              </p>
              <div class="listings-empty-actions">
                <a href={`tel:${site.contact.phone}`} class="btn btn-primary">
                  {site.contact.phoneDisplay}
                </a>
                <a
                  href={`https://wa.me/${site.contact.whatsapp}`}
                  class="btn btn-ghost"
                  rel="noopener"
                >
                  WhatsApp'tan yazın
                </a>
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .listings-head-section {
    padding: calc(var(--header-h) + 2.5rem) 0 1.5rem;
    background: var(--color-paper-deep);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--color-ink);
  }

  .listings-head-section h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.06;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .listings-lead {
    max-width: 62ch;
    color: var(--color-ink-muted);
    font-size: 1.05rem;
    line-height: 1.66;
    margin: 0;
  }

  /* ── Kart ızgarası ── */
  .listing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.6rem;
  }

  .listing-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s var(--ease-out), box-shadow 0.3s, border-color 0.2s;
  }

  .listing-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .listing-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg);
  }

  .listing-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }

  .listing-card:hover .listing-card-media img {
    transform: scale(1.05);
  }

  .listing-badge {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    padding: 0.35rem 0.8rem;
    border-radius: var(--radius-sm);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    backdrop-filter: blur(4px);
  }

  .listing-badge--satilik {
    background: var(--color-eyebrow);
  }

  .listing-badge--kiralik {
    background: var(--color-navy);
  }

  .listing-card-body {
    padding: 1.3rem 1.4rem 1.45rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .listing-card-loc {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 0.5rem;
  }

  .listing-card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.28;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
  }

  .listing-card-summary {
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 1.1rem;
  }

  .listing-card-go {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .listing-card-go svg {
    transition: transform 0.2s var(--ease-out);
  }

  .listing-card:hover .listing-card-go svg {
    transform: translateX(3px);
  }

  /* ── Boş durum ── */
  .listings-empty {
    max-width: 560px;
    margin: 1rem auto 2rem;
    text-align: center;
    padding: clamp(2.5rem, 5vw, 4rem) 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .listings-empty-label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin: 0 0 0.85rem;
  }

  .listings-empty h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.18;
    color: var(--color-ink);
    margin: 0 0 0.9rem;
  }

  .listings-empty p {
    color: var(--color-ink-muted);
    line-height: 1.66;
    margin: 0 0 1.6rem;
  }

  .listings-empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
