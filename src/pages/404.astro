---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { regions } from "../data/regions";
import { services, site } from "../data/config";

const title = `Sayfa bulunamadı (404) | ${site.name}`;
const description =
  "Aradığınız sayfa bulunamadı. Çolakoğlu Emlak — Muğla genelinde gayrimenkul danışmanlığı. Ana sayfa, hizmetler veya 13 ilçe sayfasından devam edin.";
---

<Layout title={title} description={description} noindex={true}>
  <Header />
  <main id="main" class="err-page">
    <section class="err-hero">
      <div class="container err-hero-inner">
        <p class="err-code">404</p>
        <h1>Aradığınız sayfayı bulamadık.</h1>
        <p class="err-lead">
          Adres yanlış yazılmış olabilir, sayfa taşınmış olabilir veya artık
          mevcut değil. Aşağıdan size uygun bir yere geçebilirsiniz.
        </p>
        <div class="err-actions">
          <a href="/" class="btn btn-primary">Ana sayfaya dön</a>
          <a href="/#iletisim" class="btn err-ghost">İletişim</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <header class="section-head section-head-center">
          <p class="eyebrow">Sık ziyaret edilen</p>
          <h2>Belki şunlardan birini arıyordunuz</h2>
        </header>

        <div class="err-grid">
          <div class="err-block">
            <h3>Hizmetler</h3>
            <ul>
              {services.map((s) => (
                <li><a href={`/hizmetler/${s.slug}/`}>{s.name}</a></li>
              ))}
            </ul>
          </div>

          <div class="err-block">
            <h3>Bölgeler</h3>
            <ul class="err-regions">
              {regions.map((r) => (
                <li><a href={`/bolgeler/${r.slug}/`}>{r.name}</a></li>
              ))}
            </ul>
          </div>

          <div class="err-block">
            <h3>Rehber</h3>
            <ul>
              <li><a href="/rehber/">Tüm rehber</a></li>
              <li><a href="/rehber/tapu-devir-sureci/">Tapu Devir Süreci</a></li>
              <li><a href="/rehber/yabanciya-gayrimenkul-satisi/">Yabancıya Gayrimenkul Satışı</a></li>
              <li><a href="/rehber/muglada-yatirimlik-arazi/">Muğla Yatırımlık Arazi</a></li>
              <li><a href="/vizyon-misyon/">Vizyon ve Misyon</a></li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .err-page { padding-top: var(--header-h); }

  .err-hero {
    background: var(--color-wood-deep);
    padding: clamp(3rem, 7vw, 5rem) 0;
    text-align: center;
  }

  .err-hero-inner { max-width: 720px; margin: 0 auto; }

  .err-code {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--color-gold-bright);
    margin: 0 0 0.5rem;
  }

  .err-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .err-lead {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.02rem;
    line-height: 1.65;
    margin: 0 0 1.75rem;
  }

  .err-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .err-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  .err-ghost:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: #fff;
    color: #fff;
  }

  .err-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 760px) {
    .err-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .err-block {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1.85rem 1.9rem;
    box-shadow: var(--shadow-card);
  }

  .err-block h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 800;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }

  .err-block ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .err-block a {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .err-block a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }

  .err-regions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem 1rem;
  }
</style>
