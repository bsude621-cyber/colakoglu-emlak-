---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { site } from "../../data/config";

const title = `Gayrimenkul Rehberi | ${site.name} — Muğla`;
const description =
  "Muğla'da gayrimenkul alım, satım ve yatırımı için uzman rehberleri — yatırımlık arazi seçimi, tapu süreci, imar ve daha fazlası. Çolakoğlu Emlak.";
const canonical = `${site.url}/rehber/`;

// Yayınlanan rehber içerikleri — yeni makale eklemek için diziye eklemek yeterli.
const articles = [
  {
    slug: "muglada-yatirimlik-arazi",
    image: "/images/rehber-yatirimlik-arazi.webp",
    category: "Gayrimenkul Yatırımı",
    title: "Muğla'da Yatırımlık Arazi Nasıl Seçilir?",
    excerpt:
      "İmar durumu, tapu kaydı, kadastro, zeytinlik ve SİT alanı kısıtları — Muğla'da arazi yatırımında adım adım nelere dikkat edilmeli?",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "7 dk okuma",
  },
  {
    slug: "tapu-devir-sureci",
    image: "/images/rehber-tapu-devir.webp",
    category: "Alım Satım Süreci",
    title: "Tapu Devir İşlemleri Adım Adım Nasıl Yapılır?",
    excerpt:
      "Web-Tapu randevusu, gerekli belgeler, tapu harcı ve döner sermaye bedeli, randevu günü süreci — tapu devri adım adım.",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "6 dk okuma",
  },
  {
    slug: "yabanciya-gayrimenkul-satisi",
    image: "/images/rehber-yabanciya-satis.webp",
    category: "Yabancı Yatırımcı",
    title: "Yabancıya Gayrimenkul Satışı: Kurallar ve Süreç",
    excerpt:
      "Alan ve bölge sınırları, değerleme raporu, satış süreci ve gayrimenkulle Türk vatandaşlığı — Muğla'da yabancıya satış rehberi.",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "7 dk okuma",
  },
];

// Mevzuat kütüphanesi — emlak süreçlerini ilgilendiren temel kanun/yönetmelikler.
const mevzuat = [
  {
    slug: "imar-kanunu",
    title: "İmar Kanunu: Emlak Alıcısının Bilmesi Gerekenler",
    excerpt:
      "İmar planı türleri, imar durumu belgesi, TAKS/KAKS, yapı ruhsatı ve iskan — 3194 sayılı kanun emlak alıcısı için ne anlama gelir?",
  },
  {
    slug: "kat-mulkiyeti-kanunu",
    title: "Kat Mülkiyeti Kanunu: Daire Alırken Bilinmesi Gerekenler",
    excerpt:
      "Kat mülkiyeti–kat irtifakı farkı, arsa payı, ortak yerler, yönetim planı ve aidat — 634 sayılı kanun sade dille.",
  },
  {
    slug: "tasinmaz-ticareti-yonetmeligi",
    title: "Taşınmaz Ticareti Yönetmeliği ve Yetkili Emlakçı",
    excerpt:
      "Yetki belgesi şartları, TTBS doğrulaması, yazılı sözleşme ve hizmet bedeli — yetkili emlakçı nasıl anlaşılır?",
  },
  {
    slug: "zeytinlik-sit-alanlari",
    title: "Zeytinlik ve SİT Alanları: Muğla'da Arazi Alırken Dikkat",
    excerpt:
      "Zeytincilik Kanunu, SİT türleri ve yapılaşma kuralları — Muğla'da arazi alımının en sık iki kısıtı.",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Rehber", item: canonical },
  ],
};

const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${canonical}#webpage`,
  name: `Gayrimenkul Rehberi — ${site.name}`,
  description,
  url: canonical,
  inLanguage: "tr-TR",
  isPartOf: { "@id": `${site.url}/#website` },
  about: { "@id": `${site.url}/#organization` },
  breadcrumb: { "@id": `${canonical}#breadcrumb` },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [...articles, ...mevzuat].map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${site.url}/rehber/${a.slug}/`,
      name: a.title,
    })),
  },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, collectionPage]}
>
  <Header />
  <main id="main" class="rehber-page">
    <section class="rehber-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">Rehber</span>
        </nav>
        <p class="eyebrow">{site.name} · Rehber</p>
        <h1>Gayrimenkul Rehberi</h1>
        <p class="rehber-lead">
          Muğla'da doğru gayrimenkul kararı için uzman rehberleri — yatırım,
          tapu, imar ve süreç bilgileri. 32 yıllık saha tecrübesine dayanan,
          anlaşılır ve güvenilir.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="rehber-section-title">Rehber Makaleleri</h2>
        <div class="rehber-list">
          {
            articles.map((a) => (
              <a class="rehber-card" href={`/rehber/${a.slug}/`}>
                <div class="rehber-card-img">
                  <img src={a.image} alt={a.title} loading="lazy" decoding="async" />
                </div>
                <div class="rehber-card-body">
                  <span class="rehber-card-cat">{a.category}</span>
                  <h3>{a.title}</h3>
                  <p>{a.excerpt}</p>
                  <span class="rehber-card-meta">
                    <time datetime={a.date}>{a.dateText}</time>
                    <span aria-hidden="true">·</span>
                    <span>{a.readTime}</span>
                    <span class="rehber-card-go">Oku →</span>
                  </span>
                </div>
              </a>
            ))
          }
        </div>

        <h2 class="rehber-section-title rehber-section-title--gap">
          Mevzuat Kütüphanesi
        </h2>
        <p class="rehber-section-desc">
          Emlak süreçlerini ilgilendiren temel kanun ve yönetmelikler — sade
          dille, resmî kaynak bağlantılarıyla.
        </p>
        <div class="mevzuat-grid">
          {
            mevzuat.map((m) => (
              <a class="mevzuat-card" href={`/rehber/${m.slug}/`}>
                <span class="mevzuat-card-tag">Mevzuat</span>
                <h3>{m.title}</h3>
                <p>{m.excerpt}</p>
                <span class="mevzuat-card-go">Oku →</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .rehber-page {
    padding-top: var(--header-h);
  }

  .rehber-hero {
    padding: calc(4rem + 1rem) 0 3rem;
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 2px solid var(--color-gold);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--color-ink-muted);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--color-ink);
  }

  .rehber-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .rehber-lead {
    max-width: 56ch;
    color: var(--color-ink-muted);
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0;
  }

  .rehber-section-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    max-width: 820px;
    margin: 0 auto 1.5rem;
  }

  .rehber-section-title--gap {
    margin-top: 3.5rem;
  }

  .rehber-section-desc {
    max-width: 820px;
    margin: -0.85rem auto 1.85rem;
    color: var(--color-ink-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .rehber-list {
    max-width: 820px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mevzuat-grid {
    max-width: 820px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .mevzuat-grid {
      grid-template-columns: 1fr;
    }
  }

  .mevzuat-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.6rem 1.7rem;
    text-decoration: none;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s, border-color 0.25s;
  }

  .mevzuat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .mevzuat-card-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin-bottom: 0.7rem;
  }

  .mevzuat-card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.26;
    color: var(--color-ink);
    margin: 0 0 0.55rem;
  }

  .mevzuat-card p {
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 1.1rem;
  }

  .mevzuat-card-go {
    margin-top: auto;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--color-accent);
  }

  .rehber-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.25s var(--ease-out), box-shadow 0.25s, border-color 0.25s;
  }

  .rehber-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .rehber-card-img {
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .rehber-card-img img {
    width: 100%;
    height: 100%;
    min-height: 210px;
    object-fit: cover;
    display: block;
  }

  .rehber-card-body {
    padding: 1.85rem 2rem;
  }

  @media (max-width: 640px) {
    .rehber-card {
      grid-template-columns: 1fr;
    }

    .rehber-card-img img {
      min-height: 0;
      aspect-ratio: 16 / 9;
    }
  }

  .rehber-card-cat {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin-bottom: 0.7rem;
  }

  .rehber-card h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.4vw, 1.65rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
  }

  .rehber-card p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 1.1rem;
  }

  .rehber-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.83rem;
    color: var(--color-ink-muted);
  }

  .rehber-card-go {
    margin-left: auto;
    font-weight: 700;
    color: var(--color-accent);
  }
</style>
