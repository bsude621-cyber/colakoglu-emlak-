---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { site } from "../../data/config";

const title = `Gayrimenkul Rehberi | ${site.name} — Muğla`;
const description =
  "Muğla'da gayrimenkul alım, satım ve yatırımı için uzman rehberleri — yatırımlık arazi seçimi, tapu süreci, imar ve daha fazlası. Çolakoğlu Emlak.";
const canonical = `${site.url}/rehber/`;

// Yayınlanan rehber içerikleri — yeni makale eklemek için diziye eklemek yeterli.
const articles = [
  {
    slug: "muglada-yatirimlik-arazi",
    image: "/images/rehber-yatirimlik-arazi.webp",
    category: "Gayrimenkul Yatırımı",
    title: "Muğla'da Yatırımlık Arazi Nasıl Seçilir?",
    excerpt:
      "İmar durumu, tapu kaydı, kadastro, zeytinlik ve SİT alanı kısıtları — Muğla'da arazi yatırımında adım adım nelere dikkat edilmeli?",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "7 dk okuma",
  },
  {
    slug: "tapu-devir-sureci",
    image: "/images/rehber-tapu-devir.webp",
    category: "Alım Satım Süreci",
    title: "Tapu Devir İşlemleri Adım Adım Nasıl Yapılır?",
    excerpt:
      "Web-Tapu randevusu, gerekli belgeler, tapu harcı ve döner sermaye bedeli, randevu günü süreci — tapu devri adım adım.",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "6 dk okuma",
  },
  {
    slug: "yabanciya-gayrimenkul-satisi",
    image: "/images/rehber-yabanciya-satis.webp",
    category: "Yabancı Yatırımcı",
    title: "Yabancıya Gayrimenkul Satışı: Kurallar ve Süreç",
    excerpt:
      "Alan ve bölge sınırları, değerleme raporu, satış süreci ve gayrimenkulle Türk vatandaşlığı — Muğla'da yabancıya satış rehberi.",
    date: "2026-05-20",
    dateText: "20 Mayıs 2026",
    readTime: "7 dk okuma",
  },
];

// Mevzuat kütüphanesi — emlak süreçlerini ilgilendiren temel kanun/yönetmelikler.
const mevzuat = [
  {
    slug: "imar-kanunu",
    code: "3194",
    title: "İmar Kanunu: Emlak Alıcısının Bilmesi Gerekenler",
    excerpt:
      "İmar planı türleri, imar durumu belgesi, TAKS/KAKS, yapı ruhsatı ve iskan — 3194 sayılı kanun emlak alıcısı için ne anlama gelir?",
  },
  {
    slug: "kat-mulkiyeti-kanunu",
    code: "634",
    title: "Kat Mülkiyeti Kanunu: Daire Alırken Bilinmesi Gerekenler",
    excerpt:
      "Kat mülkiyeti–kat irtifakı farkı, arsa payı, ortak yerler, yönetim planı ve aidat — 634 sayılı kanun sade dille.",
  },
  {
    slug: "tasinmaz-ticareti-yonetmeligi",
    code: "Yön.",
    title: "Taşınmaz Ticareti Yönetmeliği ve Yetkili Emlakçı",
    excerpt:
      "Yetki belgesi şartları, TTBS doğrulaması, yazılı sözleşme ve hizmet bedeli — yetkili emlakçı nasıl anlaşılır?",
  },
  {
    slug: "zeytinlik-sit-alanlari",
    code: "3573",
    title: "Zeytinlik ve SİT Alanları: Muğla'da Arazi Alırken Dikkat",
    excerpt:
      "Zeytincilik Kanunu, SİT türleri ve yapılaşma kuralları — Muğla'da arazi alımının en sık iki kısıtı.",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: site.url },
    { "@type": "ListItem", position: 2, name: "Rehber", item: canonical },
  ],
};

const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${canonical}#webpage`,
  name: `Gayrimenkul Rehberi — ${site.name}`,
  description,
  url: canonical,
  inLanguage: "tr-TR",
  isPartOf: { "@id": `${site.url}/#website` },
  about: { "@id": `${site.url}/#organization` },
  breadcrumb: { "@id": `${canonical}#breadcrumb` },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [...articles, ...mevzuat].map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${site.url}/rehber/${a.slug}/`,
      name: a.title,
    })),
  },
};

const romans = ["I", "II", "III", "IV", "V", "VI"];
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[breadcrumb, collectionPage]}
>
  <Header />
  <main id="main" class="rehber-page">
    <!-- Koyu bilgi-merkezi hero'su -->
    <section class="rehber-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Rehber</span>
        </nav>

        <div class="rehber-hero-grid">
          <div class="rehber-hero-main">
            <p class="eyebrow">{site.name} · Bilgi Merkezi</p>
            <h1>Gayrimenkul Rehberi</h1>
            <p class="rehber-lead">
              Muğla'da doğru gayrimenkul kararı için uzman rehberleri —
              yatırım, tapu, imar ve mevzuat. 32 yıllık saha tecrübesine
              dayanan, anlaşılır ve güvenilir.
            </p>
          </div>

          <nav class="rehber-index" aria-label="Rehber içindekiler">
            <p class="rehber-index-label">İçindekiler</p>
            <a class="rehber-index-item" href="#makaleler">
              <span class="rehber-index-num">01</span>
              <span class="rehber-index-name">Rehber Makaleleri</span>
              <span class="rehber-index-count">{articles.length} yazı</span>
            </a>
            <a class="rehber-index-item" href="#mevzuat">
              <span class="rehber-index-num">02</span>
              <span class="rehber-index-name">Mevzuat Kütüphanesi</span>
              <span class="rehber-index-count">{mevzuat.length} başlık</span>
            </a>
          </nav>
        </div>
      </div>
    </section>

    <!-- Rehber makaleleri -->
    <section class="section" id="makaleler">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Uzman İçerik</p>
          <h2>Rehber Makaleleri</h2>
          <p class="section-desc">
            Sahadan gelen, adım adım anlatan, güncel rehberler.
          </p>
        </header>

        <div class="rehber-grid">
          {
            articles.map((a) => (
              <a class="rehber-card" href={`/rehber/${a.slug}/`}>
                <div class="rehber-card-img">
                  <img
                    src={a.image}
                    alt={a.title}
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="rehber-card-cat">{a.category}</span>
                </div>
                <div class="rehber-card-body">
                  <h3>{a.title}</h3>
                  <p>{a.excerpt}</p>
                  <span class="rehber-card-meta">
                    <time datetime={a.date}>{a.dateText}</time>
                    <span aria-hidden="true">·</span>
                    <span>{a.readTime}</span>
                    <span class="rehber-card-go" aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Mevzuat kütüphanesi -->
    <section class="section section-mevzuat" id="mevzuat">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Resmî Kaynak</p>
          <h2>Mevzuat Kütüphanesi</h2>
          <p class="section-desc">
            Emlak süreçlerini ilgilendiren temel kanun ve yönetmelikler — sade
            dille, resmî kaynak bağlantılarıyla.
          </p>
        </header>

        <div class="mevzuat-grid">
          {
            mevzuat.map((m, i) => (
              <a class="mevzuat-card" href={`/rehber/${m.slug}/`}>
                <div class="mevzuat-card-top">
                  <span class="mevzuat-card-rn">{romans[i]}</span>
                  <span class="mevzuat-card-code">{m.code}</span>
                </div>
                <h3>{m.title}</h3>
                <p>{m.excerpt}</p>
                <span class="mevzuat-card-go">
                  İncele
                  <svg
                    viewBox="0 0 24 24"
                    width="15"
                    height="15"
                    aria-hidden="true"
                  >
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.9"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 12h14M13 6l6 6-6 6"
                    />
                  </svg>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ---- Koyu hero ---- */
  .rehber-hero {
    background: var(--color-wood-deep);
    padding: calc(var(--header-h) + 3.5rem) 0 clamp(3rem, 6vw, 4.5rem);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold-bright);
  }

  .breadcrumb [aria-current="page"] {
    color: rgba(255, 255, 255, 0.9);
  }

  .rehber-hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: end;
  }

  @media (max-width: 800px) {
    .rehber-hero-grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }

  .rehber-hero .eyebrow {
    color: var(--color-gold-bright);
  }

  .rehber-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: #fff;
    margin: 0 0 1.1rem;
  }

  .rehber-lead {
    max-width: 50ch;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.06rem;
    line-height: 1.66;
    margin: 0;
  }

  /* İçindekiler paneli */
  .rehber-index {
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-md);
    padding: 1.4rem 1.5rem;
    background: rgba(255, 255, 255, 0.04);
  }

  .rehber-index-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-bright);
    margin: 0 0 0.4rem;
  }

  .rehber-index-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.8rem;
    padding: 0.95rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    transition: padding-left 0.2s var(--ease-out);
  }

  .rehber-index-item:last-child {
    border-bottom: none;
  }

  .rehber-index-item:hover {
    padding-left: 0.35rem;
    text-decoration: none;
  }

  .rehber-index-num {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--color-gold-bright);
  }

  .rehber-index-name {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .rehber-index-count {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ---- Makale ızgarası ---- */
  .rehber-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .rehber-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 620px) {
    .rehber-grid {
      grid-template-columns: 1fr;
    }
  }

  .rehber-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition:
      transform 0.25s var(--ease-out),
      box-shadow 0.25s,
      border-color 0.25s;
  }

  .rehber-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .rehber-card-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-paper-deep);
  }

  .rehber-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease-out);
  }

  .rehber-card:hover .rehber-card-img img {
    transform: scale(1.04);
  }

  .rehber-card-cat {
    position: absolute;
    left: 0.9rem;
    bottom: 0.9rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: var(--color-navy);
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-sm);
  }

  .rehber-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem 1.6rem 1.6rem;
  }

  .rehber-card h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.24;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
  }

  .rehber-card p {
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 1.2rem;
  }

  .rehber-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  .rehber-card-go {
    margin-left: auto;
    font-size: 1.05rem;
    color: var(--color-gold);
    transition: transform 0.2s var(--ease-out);
  }

  .rehber-card:hover .rehber-card-go {
    transform: translateX(3px);
  }

  /* ---- Mevzuat ---- */
  .section-mevzuat {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-line);
  }

  .mevzuat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 680px) {
    .mevzuat-grid {
      grid-template-columns: 1fr;
    }
  }

  .mevzuat-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 1.7rem 1.8rem;
    text-decoration: none;
    transition:
      transform 0.25s var(--ease-out),
      box-shadow 0.25s,
      border-color 0.25s;
  }

  .mevzuat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-soft);
    border-color: var(--color-navy);
    text-decoration: none;
  }

  .mevzuat-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.9rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--color-line);
  }

  .mevzuat-card-rn {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-gold);
  }

  .mevzuat-card-code {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.6rem;
  }

  .mevzuat-card h3 {
    font-family: var(--font-serif);
    font-size: 1.22rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.28;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
  }

  .mevzuat-card p {
    font-size: 0.94rem;
    line-height: 1.62;
    color: var(--color-ink-muted);
    margin: 0 0 1.2rem;
  }

  .mevzuat-card-go {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .mevzuat-card-go svg {
    transition: transform 0.2s var(--ease-out);
  }

  .mevzuat-card:hover .mevzuat-card-go svg {
    transform: translateX(3px);
  }
</style>
