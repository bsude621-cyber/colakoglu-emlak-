---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/config";

const title = `Aydınlatma Metni | ${site.name}`;
const description =
  "Çolakoğlu Emlak — KVKK 10. madde kapsamında veri sahibinin aydınlatılması; veri sorumlusu kimliği, işleme amaçları, aktarılan taraflar ve haklarınız.";
const canonical = `${site.url}/aydinlatma-metni/`;
const updatedDate = "2026-05-23";
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
>
  <Header />
  <main id="main" class="legal-page">
    <header class="legal-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Sayfa konumu">
          <a href="/">Ana Sayfa</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Aydınlatma Metni</span>
        </nav>
        <p class="eyebrow">Yasal Bilgilendirme</p>
        <h1>Aydınlatma Metni</h1>
        <p class="legal-meta">
          Son güncelleme: <time datetime={updatedDate}>23 Mayıs 2026</time>
        </p>
      </div>
    </header>

    <article class="container legal-body">
      <section>
        <p>
          6698 sayılı Kişisel Verilerin Korunması Kanunu'nun ("KVKK") 10.
          maddesi uyarınca, veri sorumlusu sıfatıyla aşağıdaki bilgileri
          dikkatinize sunarız.
        </p>
      </section>

      <section>
        <h2>1. Veri Sorumlusunun Kimliği</h2>
        <p>
          <strong>Veri Sorumlusu:</strong> {site.name} (Ziya Ercan / Sahibi)<br />
          <strong>Adres:</strong> {site.address.street}, {site.address.locality}/{site.address.region}<br />
          <strong>İş Telefonu:</strong> {site.contact.phoneDisplay}<br />
          <strong>GSM:</strong> {site.contact.mobileDisplay}
        </p>
      </section>

      <section>
        <h2>2. Kişisel Verilerin Hangi Amaçla İşleneceği</h2>
        <p>
          Web sitemiz, telefon, WhatsApp veya yüz yüze görüşmeler aracılığıyla
          paylaştığınız kişisel verileriniz; gayrimenkul danışmanlığı
          hizmetimizin sunulması, talep ve sorularınızın yanıtlanması, ihtiyaç
          analizinin yapılması, uygun gayrimenkul önerisinin sunulması,
          sözleşme süreçlerinin yürütülmesi, hukuki yükümlülüklerin
          karşılanması ve müşteri ilişkilerinin yönetilmesi amaçlarıyla
          işlenmektedir.
        </p>
      </section>

      <section>
        <h2>3. Aktarılan Üçüncü Taraflar</h2>
        <p>
          Kişisel verileriniz; yasal yükümlülüklerin yerine getirilmesi ve
          danışmanlık sürecinin yürütülmesi amacıyla, mevzuat gereği yetkili
          kamu kurum ve kuruluşlarına (Tapu Müdürlüğü, vergi daireleri vb.),
          hukuki ve mali müşavir iş ortaklarımıza aktarılabilir. Kişisel
          verileriniz yurt dışına aktarılmamaktadır.
        </p>
      </section>

      <section>
        <h2>4. Verilerinizin Toplanma Yöntemi ve Hukuki Sebebi</h2>
        <p>
          Kişisel verileriniz; iletişim formu, telefon görüşmesi, WhatsApp
          mesajlaşma veya yüz yüze görüşmeler kanalıyla sözlü veya yazılı
          olarak toplanmaktadır. İşleme faaliyetinin hukuki sebepleri; KVKK m.5
          kapsamında sözleşmenin kurulması ve ifası, hukuki yükümlülüklerin
          yerine getirilmesi, meşru menfaatlerin korunması ve açık rızanızdır.
        </p>
      </section>

      <section>
        <h2>5. KVKK m.11 Kapsamındaki Haklarınız</h2>
        <p>
          KVKK'nın 11. maddesi uyarınca; kişisel verilerinizin işlenip
          işlenmediğini öğrenme, işlenmişse bilgi talep etme, işleme amacını
          öğrenme, yurt içinde aktarılan üçüncü kişileri bilme, eksik veya
          yanlış işlenmiş verinin düzeltilmesini isteme, kanuna uygun olarak
          silinmesini isteme, otomatik sistemler vasıtasıyla analiz edilmesine
          itiraz etme ve zarara uğramanız hâlinde zararın giderilmesini talep
          etme haklarına sahipsiniz.
        </p>
        <p>
          Detaylı bilgi ve başvuru süreci için
          <a href="/kvkk/">KVKK Politikamız</a> sayfasını inceleyebilirsiniz.
        </p>
      </section>

      <section class="legal-cta">
        <p>
          KVKK kapsamında sorunuz için bize ulaşın.
        </p>
        <a href="/#iletisim" class="btn btn-primary">İletişim</a>
      </section>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .legal-page { padding-top: var(--header-h); }
  .legal-hero { padding: calc(var(--header-h) + 2.5rem) 0 clamp(2rem, 4vw, 3rem); background: var(--color-wood-deep); }
  .legal-hero .eyebrow { color: var(--color-gold-bright); }
  .breadcrumb { display: flex; align-items: center; flex-wrap: wrap; gap: 0.45rem; font-size: 0.8rem; color: rgba(255,255,255,0.6); margin-bottom: 1.5rem; }
  .breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-gold-bright); text-decoration: none; }
  .breadcrumb [aria-current="page"] { color: #fff; }
  .legal-hero h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.08; color: #fff; margin: 0 0 1rem; }
  .legal-meta { margin: 0; font-size: 0.85rem; color: rgba(255,255,255,0.62); }
  .legal-body { max-width: 760px; padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 5rem); }
  .legal-body section { margin-bottom: 2.5rem; }
  .legal-body h2 { font-family: var(--font-serif); font-size: clamp(1.3rem, 2.2vw, 1.5rem); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--color-ink); }
  .legal-body p { margin: 0 0 1rem; font-size: 1rem; line-height: 1.72; color: var(--color-ink-muted); }
  .legal-body strong { color: var(--color-ink); }
  .legal-body a { color: var(--color-accent); font-weight: 600; }
  .legal-cta { margin-top: 3rem; padding: 2rem 1.85rem; background: var(--color-paper-deep); border-left: 3px solid var(--color-gold); border-radius: var(--radius-md); }
  .legal-cta p { margin: 0 0 1rem; font-family: var(--font-serif); font-size: 1.1rem; color: var(--color-ink); }
</style>
