---
import { site } from "../data/config";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
}

const {
  title = `${site.name} | ${site.tagline}`,
  description = site.description,
  canonical = Astro.url.href,
  ogImage = `${site.url}/og-default.jpg`,
  noindex = false,
  jsonLd,
} = Astro.props;

const titleFull = title.includes(site.name) ? title : `${title} | ${site.name}`;
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#f5f0e8" />
    <meta name="format-detection" content="telephone=yes" />
    <meta name="geo.region" content="TR-48" />
    <meta name="geo.placename" content="Muğla" />
    <meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
    <meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {/* LCP boost — hero AVIF preload (only on home — heuristic: canonical ends at root) */}
    {(canonical === site.url || canonical === `${site.url}/`) && (
      <link
        rel="preload"
        as="image"
        href="/images/oludeniz-hero-1659.avif?v=2"
        type="image/avif"
        imagesrcset="/images/oludeniz-hero-800.avif?v=2 800w, /images/oludeniz-hero-1200.avif?v=2 1200w, /images/oludeniz-hero-1659.avif?v=2 1659w"
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}

    <!-- Archivo self-host via @fontsource (global.css @import) — render-blocking sıfır, woff2 dist/_astro/'da hash'li serve edilir -->


    {ldArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- Speculation Rules API — Chrome 121+ hover prerender (perceived 0ms navigation) -->
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [
        {
          where: {
            and: [
              { href_matches: "/*" },
              { not: { href_matches: "/*\\?*" } },
              { not: { href_matches: "/*#*" } },
            ],
          },
          eagerness: "moderate",
        },
      ],
    })} />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">İçeriğe geç</a>
    <slot />
    <script src="/script.js" defer></script>
    <!-- PWA — service worker register (offline cache + repeat visitor) -->
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
  </body>
</html>
